    private async Task StartGame()
    {
        if (string.IsNullOrWhiteSpace(_playerName)) return;

        _gameState = await GameClient.StartGameAsync(_playerName, _selectedAgeMode, _selectedLanguage);
        _isPaused = false;
        await ApplyTheme();

        // Initialize stock lots dictionary
        if (_gameState?.AvailableStocks != null)
        {
            foreach (var stock in _gameState.AvailableStocks)
            {
                _stockLots[stock.Ticker] = 1;
            }
        }

        // Initialize crypto amounts dictionary
        if (_gameState?.AvailableCryptos != null)
        {
            foreach (var crypto in _gameState.AvailableCryptos)
            {
                _cryptoAmounts[crypto.Symbol] = 1_000_000;
            }
        }

        StateHasChanged();
    }

