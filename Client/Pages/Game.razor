        }
        if (gold > 0)
        {
            segments.Add($"#FFD700 {cumulative}% {cumulative + gold}%");
            cumulative += gold;
        }

        if (!segments.Any()) return "background: #ccc;";

        return $"background: conic-gradient({string.Join(", ", segments)});";
    }

    private decimal GetPlayerProfit()
    {
        if (_gameState == null) return 0;
        var initialCapital = 5_000_000m;
        var yearlyIncome = 10_000_000m * (_gameState.CurrentYear - 1);
        var totalInvested = initialCapital + yearlyIncome;
        return _gameState.NetWorth - totalInvested;
    }

    private decimal GetPlayerProfitPercent()
    {
        if (_gameState == null) return 0;
        var initialCapital = 5_000_000m;
        var yearlyIncome = 10_000_000m * (_gameState.CurrentYear - 1);
        var totalInvested = initialCapital + yearlyIncome;
        if (totalInvested <= 0) return 0;
        return ((_gameState.NetWorth - totalInvested) / totalInvested) * 100;
    }

    private string GetLogClass(string log)
    {
        // Salary - dark green
        if (log.Contains("gaji tahunan") || log.Contains("Annual income received"))
            return "log-salary";

        // Event payment (deduction) - dark red
        if (log.Contains("Bayar") || log.Contains("Paid"))
            return "log-event-payment";

        // Profit from selling - green
        if (log.Contains("untung") || log.Contains("P/L: +"))
            return "log-profit";

        // Loss from selling - red
        if (log.Contains("rugi") || log.Contains("P/L: -"))
            return "log-loss";

        // Event trigger - default event styling
        if (log.Contains("EVENT"))
            return "event";

        // Asset unlock - default unlock styling
        if (log.Contains("terbuka") || log.Contains("BARU") || log.Contains("unlocked"))
            return "unlock";

        return "";
    }

    // === MULTIPLAYER METHODS ===

    private async Task CreateRoom()
    {
        _isCreatingRoom = true;
        _roomError = null;
        StateHasChanged();

        try
        {
            var room = await GameClient.CreateRoomAsync(_playerName, _selectedAgeMode, _selectedLanguage, _maxPlayers);
            if (room != null)
            {
                _currentRoom = room;
                _isHost = true;
                _isReady = true;
                _multiplayerScreen = "lobby";
            }
            else
            {
                _roomError = _selectedLanguage == Language.Indonesian ? "Gagal membuat room" : "Failed to create room";
            }
        }
        catch (Exception ex)
        {
            _roomError = ex.Message;
        }
        finally
        {
            _isCreatingRoom = false;
            StateHasChanged();
        }
    }

    private async Task JoinRoom()
    {
        if (string.IsNullOrWhiteSpace(_roomCodeInput) || _roomCodeInput.Length != 6) return;

        _isJoiningRoom = true;
        _roomError = null;
        StateHasChanged();

        try
        {
            var room = await GameClient.JoinRoomAsync(_roomCodeInput.ToUpper(), _playerName);
            if (room != null)
            {
                _currentRoom = room;
                _isHost = false;
                _isReady = false;
                _selectedLanguage = room.Language;
                _isLightMode = room.AgeMode == AgeMode.Kids;
                _multiplayerScreen = "lobby";
            }
            // Error is handled via OnRoomError callback
        }
        catch (Exception ex)
        {
            _roomError = ex.Message;
        }
        finally
        {
            _isJoiningRoom = false;
            StateHasChanged();
        }
    }

    private async Task LeaveRoom()
    {
        await GameClient.LeaveRoomAsync();
        _currentRoom = null;
        _isHost = false;
        _isReady = false;
        _multiplayerScreen = "none";
        _gameState = null;
        _leaderboard = null;
        StateHasChanged();
    }

    private async Task ToggleReady()
    {
        _isReady = !_isReady;
        await GameClient.SetReadyAsync(_isReady);
    }

    private async Task StartMultiplayerGame()
    {
        var success = await GameClient.StartMultiplayerGameAsync();
        if (!success)
        {
            // Error handled via OnRoomError callback
        }
    }

    private void BackToMenu()
    {
        _gameState = null;
        _currentRoom = null;
        _isHost = false;
        _isReady = false;
        _multiplayerScreen = "none";
        _leaderboard = null;
        _performanceHistory.Clear();
        StateHasChanged();
    }

    // === MULTIPLAYER EVENT HANDLERS ===

    private void HandleRoomUpdated(RoomInfo room)
    {
        _currentRoom = room;
        _isHost = room.HostConnectionId == room.Players.FirstOrDefault(p => p.PlayerName == _playerName)?.ConnectionId;
        InvokeAsync(StateHasChanged);
    }

    private void HandleRoomGameStarted(GameState state)
    {
        _gameState = state;
        _isHost = state.IsHost;
        _multiplayerScreen = "playing";
        _isPaused = false;
        _performanceHistory.Clear();

        // Initialize stock/crypto/crowdfunding dictionaries
        if (state.AvailableStocks != null)
        {
            foreach (var stock in state.AvailableStocks)
                _stockLots[stock.Ticker] = 1;
        }
        if (state.AvailableCryptos != null)
        {
            foreach (var crypto in state.AvailableCryptos)
                _cryptoAmounts[crypto.Symbol] = 1_000_000;
        }

        InvokeAsync(async () =>
        {
            await ApplyTheme();
            StateHasChanged();
        });
    }

    private void HandleLeaderboardUpdated(List<LeaderboardEntry> entries)
    {
        _leaderboard = entries;
        InvokeAsync(StateHasChanged);
    }

    private void HandleAllPlayersFinished(List<LeaderboardEntry> entries)
    {
        _leaderboard = entries;
        if (_gameState != null)
        {
            _gameState.AllPlayersFinished = true;
            _gameState.FinalLeaderboard = entries;
        }
        InvokeAsync(StateHasChanged);
    }

    private void HandleRoomClosed()
    {
        _currentRoom = null;
        _multiplayerScreen = "none";
        _gameState = null;
        _leaderboard = null;
        InvokeAsync(StateHasChanged);
    }

    private void HandleRoomError(string error)
    {
        _roomError = error;
        InvokeAsync(StateHasChanged);
    }

    private void HandleLeftRoom()
    {
        _currentRoom = null;
        _multiplayerScreen = "none";
        _leaderboard = null;
        InvokeAsync(StateHasChanged);
    }

    private void HandleHostChanged(string newHostName)
    {
        _isHost = newHostName == _playerName;
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        GameClient.OnGameStateUpdated -= HandleGameStateUpdated;
        GameClient.OnGamePaused -= HandleGamePaused;
        GameClient.OnGameResumed -= HandleGameResumed;
        GameClient.OnError -= HandleError;

        // Multiplayer cleanup
        GameClient.OnRoomUpdated -= HandleRoomUpdated;
        GameClient.OnRoomGameStarted -= HandleRoomGameStarted;
        GameClient.OnLeaderboardUpdated -= HandleLeaderboardUpdated;
        GameClient.OnAllPlayersFinished -= HandleAllPlayersFinished;
        GameClient.OnRoomClosed -= HandleRoomClosed;
        GameClient.OnRoomError -= HandleRoomError;
        GameClient.OnLeftRoom -= HandleLeftRoom;
        GameClient.OnHostChanged -= HandleHostChanged;

        await GameClient.DisposeAsync();
    }
}
