@page "/"
@using InvestmentGame.Shared.Models
@inject GameClient GameClient
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Tjoean - Game Edukasi Investasi</PageTitle>

<div class="game-container">
    @if (_showTutorial)
    {
        <!-- Tutorial Modal - Art Nouveau themed -->
        <div class="tut-overlay" @onclick="SkipTutorial">
            <div class="tut-modal" @onclick:stopPropagation="true">
                <!-- Skip button -->
                <button class="tut-skip" @onclick="SkipTutorial">
                    @(_selectedLanguage == Language.Indonesian ? "Lewati" : "Skip")
                </button>

                <!-- Progress bar -->
                <div class="tut-progress">
                    <div class="tut-progress-fill" style="width: @((_currentTutorialSlide + 1) * 20)%"></div>
                </div>

                <!-- Step indicator -->
                <span class="tut-step">@(_currentTutorialSlide + 1) / 5</span>

                @if (_selectedLanguage == Language.Indonesian)
                {
                    @* ===== BAHASA INDONESIA TUTORIAL ===== *@
                    @if (_currentTutorialSlide == 0)
                    {
                        <div class="tut-slide">
                            <div class="tut-emblem">
                                <img src="images/coin-front.jpg" alt="Orang Utan Capital" />
                            </div>
                            <h2 class="tut-title">Selamat Datang di Tjoean</h2>
                            <p class="tut-text">
                                Tjoean adalah permainan edukasi yang mengajarkan literasi keuangan
                                dan investasi melalui simulasi yang realistis. Anda akan mengelola
                                keuangan selama 15 tahun dan mempelajari berbagai instrumen investasi
                                yang tersedia di Indonesia.
                            </p>
                        </div>
                    }
                    else if (_currentTutorialSlide == 1)
                    {
                        <div class="tut-slide">
                            <h2 class="tut-title">Kondisi Awal Anda</h2>
                            <div class="tut-cards">
                                <div class="tut-card">
                                    <span class="tut-card-label">Dana Investasi Individu</span>
                                    <span class="tut-card-value">Rp 5.000.000</span>
                                </div>
                                <div class="tut-card">
                                    <span class="tut-card-label">Dana Investasi Individu</span>
                                    <span class="tut-card-value">Rp 10.000.000</span>
                                </div>
                                <div class="tut-card">
                                    <span class="tut-card-label">Durasi Simulasi</span>
                                    <span class="tut-card-value">15 Tahun</span>
                                </div>
                            </div>
                            <p class="tut-hint">
                                Dana investasi individu Anda akan diterima setiap tahun.
                                Alokasikan dana tersebut dengan bijak ke berbagai instrumen investasi.
                            </p>
                        </div>
                    }
                    else if (_currentTutorialSlide == 2)
                    {
                        <div class="tut-slide">
                            <h2 class="tut-title">Instrumen Investasi</h2>
                            <p class="tut-text-sm">Instrumen baru akan terbuka seiring waktu:</p>
                            <div class="tut-timeline">
                                <div class="tut-tl-item"><span class="tut-tl-year">Tahun 1</span><span class="tut-tl-label">Tabungan, Deposito, Obligasi</span></div>
                                <div class="tut-tl-item"><span class="tut-tl-year">Tahun 2</span><span class="tut-tl-label">Reksa Dana Indeks + Emas</span></div>
                                <div class="tut-tl-item"><span class="tut-tl-year">Tahun 3</span><span class="tut-tl-label">Saham + Kripto + Urun Dana</span></div>
                            </div>
                        </div>
                    }
                    else if (_currentTutorialSlide == 3)
                    {
                        <div class="tut-slide">
                            <h2 class="tut-title">Kejadian Darurat</h2>
                            <div class="tut-alert">
                                <p class="tut-text">
                                    Mulai tahun kedua, kejadian darurat akan muncul secara acak
                                    setiap tahunnya. Anda akan membutuhkan dana
                                    sebesar Rp 2.000.000 hingga Rp 4.500.000 untuk mengatasinya.
                                </p>
                            </div>
                            <div class="tut-options">
                                <div class="tut-option">
                                    <span class="tut-option-label">Bayar dari Kas</span>
                                    <span class="tut-option-desc">Gunakan uang tunai yang tersedia</span>
                                </div>
                                <div class="tut-option">
                                    <span class="tut-option-label">Bayar dari Tabungan</span>
                                    <span class="tut-option-desc">Tarik dana dari rekening tabungan</span>
                                </div>
                                <div class="tut-option">
                                    <span class="tut-option-label">Jual Investasi</span>
                                    <span class="tut-option-desc">Cairkan sebagian portofolio Anda</span>
                                </div>
                            </div>
                        </div>
                    }
                    else if (_currentTutorialSlide == 4)
                    {
                        <div class="tut-slide">
                            <h2 class="tut-title">Tujuan Permainan</h2>
                            <p class="tut-text tut-text--highlight">
                                Maksimalkan total kekayaan bersih Anda dalam waktu 15 tahun.
                            </p>
                            <div class="tut-comparison">
                                <p class="tut-text-sm">
                                    Portofolio akhir Anda akan dibandingkan dengan portofolio AI.
                                </p>
                            </div>
                        </div>
                    }
                }
                else
                {
                    @* ===== ENGLISH TUTORIAL ===== *@
                    @if (_currentTutorialSlide == 0)
                    {
                        <div class="tut-slide">
                            <div class="tut-emblem">
                                <img src="images/coin-front.jpg" alt="Orang Utan Capital" />
                            </div>
                            <h2 class="tut-title">Welcome to Tjoean</h2>
                            <p class="tut-text">
                                Tjoean is an educational game that teaches financial literacy
                                and investment through realistic simulation. You will manage
                                your finances over 15 years and learn about various investment
                                instruments available in Indonesia.
                            </p>
                        </div>
                    }
                    else if (_currentTutorialSlide == 1)
                    {
                        <div class="tut-slide">
                            <h2 class="tut-title">Your Starting Condition</h2>
                            <div class="tut-cards">
                                <div class="tut-card">
                                    <span class="tut-card-label">Individual Investment Fund</span>
                                    <span class="tut-card-value">Rp 5,000,000</span>
                                </div>
                                <div class="tut-card">
                                    <span class="tut-card-label">Individual Investment Fund</span>
                                    <span class="tut-card-value">Rp 10,000,000</span>
                                </div>
                                <div class="tut-card">
                                    <span class="tut-card-label">Simulation Duration</span>
                                    <span class="tut-card-value">15 Years</span>
                                </div>
                            </div>
                            <p class="tut-hint">
                                Your individual investment fund will be received each year.
                                Allocate your funds wisely across different investment instruments.
                            </p>
                        </div>
                    }
                    else if (_currentTutorialSlide == 2)
                    {
                        <div class="tut-slide">
                            <h2 class="tut-title">Investment Instruments</h2>
                            <p class="tut-text-sm">New instruments unlock over time:</p>
                            <div class="tut-timeline">
                                <div class="tut-tl-item"><span class="tut-tl-year">Year 1</span><span class="tut-tl-label">Savings, Fixed Deposit, Bonds</span></div>
                                <div class="tut-tl-item"><span class="tut-tl-year">Year 2</span><span class="tut-tl-label">Index Fund + Gold</span></div>
                                <div class="tut-tl-item"><span class="tut-tl-year">Year 3</span><span class="tut-tl-label">Stocks + Crypto + Crowdfunding</span></div>
                            </div>
                        </div>
                    }
                    else if (_currentTutorialSlide == 3)
                    {
                        <div class="tut-slide">
                            <h2 class="tut-title">Emergency Events</h2>
                            <div class="tut-alert">
                                <p class="tut-text">
                                    Starting from the second year, emergency events will occur
                                    randomly each year. You will need between
                                    Rp 2,000,000 and Rp 4,500,000 to handle them.
                                </p>
                            </div>
                            <div class="tut-options">
                                <div class="tut-option">
                                    <span class="tut-option-label">Pay from Cash</span>
                                    <span class="tut-option-desc">Use your available cash on hand</span>
                                </div>
                                <div class="tut-option">
                                    <span class="tut-option-label">Pay from Savings</span>
                                    <span class="tut-option-desc">Withdraw from your savings account</span>
                                </div>
                                <div class="tut-option">
                                    <span class="tut-option-label">Sell Investments</span>
                                    <span class="tut-option-desc">Liquidate part of your portfolio</span>
                                </div>
                            </div>
                        </div>
                    }
                    else if (_currentTutorialSlide == 4)
                    {
                        <div class="tut-slide">
                            <h2 class="tut-title">Game Objective</h2>
                            <p class="tut-text tut-text--highlight">
                                Maximize your total net worth over 15 years.
                            </p>
                            <div class="tut-comparison">
                                <p class="tut-text-sm">
                                    Your final portfolio will be compared with the AI portfolio.
                                </p>
                            </div>
                        </div>
                    }
                }

                <!-- Navigation -->
                <div class="tut-nav">
                    <button class="tut-nav-btn" @onclick="PreviousTutorialSlide" disabled="@(_currentTutorialSlide == 0)">
                        @(_selectedLanguage == Language.Indonesian ? "Sebelumnya" : "Previous")
                    </button>
                    @if (_currentTutorialSlide < 4)
                    {
                        <button class="tut-nav-btn tut-nav-btn--next" @onclick="NextTutorialSlide">
                            @(_selectedLanguage == Language.Indonesian ? "Selanjutnya" : "Next")
                        </button>
                    }
                    else
                    {
                        <button class="tut-nav-btn tut-nav-btn--start" @onclick="StartGameAfterTutorial">
                            @(_selectedLanguage == Language.Indonesian ? "Mulai Permainan" : "Start Game")
                        </button>
                    }
                </div>
            </div>
        </div>
    }
    else if (_gameState == null && _multiplayerScreen == "none")
    {
        <div class="start-screen">
            <!-- Background botanical SVG decorations -->
            <div class="an-bg-botanicals">
                <svg class="an-bg-vine an-bg-vine--left" viewBox="0 0 60 400" fill="none"><path d="M30 0C20 50 10 100 15 150C20 200 10 250 15 300C20 350 15 380 20 400" stroke="currentColor" stroke-width="1"/><path d="M15 80C8 70 4 60 8 50" stroke="currentColor" stroke-width="0.6"/><path d="M15 150C5 145 2 135 6 125" stroke="currentColor" stroke-width="0.6"/><circle cx="15" cy="80" r="3" fill="currentColor" opacity="0.3"/><circle cx="15" cy="150" r="2.5" fill="currentColor" opacity="0.25"/><circle cx="18" cy="220" r="3" fill="currentColor" opacity="0.2"/><path d="M15 280C8 275 3 265 5 255" stroke="currentColor" stroke-width="0.6"/><circle cx="15" cy="280" r="2.5" fill="currentColor" opacity="0.2"/></svg>
                <svg class="an-bg-vine an-bg-vine--right" viewBox="0 0 60 400" fill="none"><path d="M30 0C40 50 50 100 45 150C40 200 50 250 45 300C40 350 45 380 40 400" stroke="currentColor" stroke-width="1"/><path d="M45 80C52 70 56 60 52 50" stroke="currentColor" stroke-width="0.6"/><path d="M45 150C55 145 58 135 54 125" stroke="currentColor" stroke-width="0.6"/><circle cx="45" cy="80" r="3" fill="currentColor" opacity="0.3"/><circle cx="45" cy="150" r="2.5" fill="currentColor" opacity="0.25"/><circle cx="42" cy="220" r="3" fill="currentColor" opacity="0.2"/></svg>
            </div>

            <!-- Art Nouveau framed content -->
            <div class="an-start-frame">
                <!-- Ornate border -->
                <svg class="an-start-border" viewBox="0 0 440 620" fill="none" preserveAspectRatio="none">
                    <rect x="6" y="6" width="428" height="608" rx="12" stroke="#C5A059" stroke-width="1.2" opacity="0.45"/>
                    <rect x="16" y="16" width="408" height="588" rx="6" stroke="#C5A059" stroke-width="0.6" opacity="0.25"/>
                    <path d="M130 16C130 16 170 2 220 2C270 2 310 16 310 16" stroke="#C5A059" stroke-width="0.8" opacity="0.35"/>
                    <path d="M130 604C130 604 170 618 220 618C270 618 310 604 310 604" stroke="#C5A059" stroke-width="0.8" opacity="0.35"/>
                </svg>

                <!-- Corner ornaments -->
                <svg class="an-start-corner an-start-corner--tl" viewBox="0 0 80 80" fill="none"><path d="M4 76C4 76 4 32 12 20C20 8 36 4 76 4" stroke="#C5A059" stroke-width="1.2" stroke-linecap="round"/><path d="M12 20C12 20 6 14 10 8C14 2 20 4 20 8C20 12 14 15 12 20Z" fill="#C5A059" opacity="0.25"/><circle cx="24" cy="9" r="2" fill="#C5A059" opacity="0.2"/></svg>
                <svg class="an-start-corner an-start-corner--tr" viewBox="0 0 80 80" fill="none"><path d="M4 76C4 76 4 32 12 20C20 8 36 4 76 4" stroke="#C5A059" stroke-width="1.2" stroke-linecap="round"/><path d="M12 20C12 20 6 14 10 8C14 2 20 4 20 8C20 12 14 15 12 20Z" fill="#C5A059" opacity="0.25"/><circle cx="24" cy="9" r="2" fill="#C5A059" opacity="0.2"/></svg>
                <svg class="an-start-corner an-start-corner--bl" viewBox="0 0 80 80" fill="none"><path d="M4 76C4 76 4 32 12 20C20 8 36 4 76 4" stroke="#C5A059" stroke-width="1.2" stroke-linecap="round"/><path d="M12 20C12 20 6 14 10 8C14 2 20 4 20 8C20 12 14 15 12 20Z" fill="#C5A059" opacity="0.25"/></svg>
                <svg class="an-start-corner an-start-corner--br" viewBox="0 0 80 80" fill="none"><path d="M4 76C4 76 4 32 12 20C20 8 36 4 76 4" stroke="#C5A059" stroke-width="1.2" stroke-linecap="round"/><path d="M12 20C12 20 6 14 10 8C14 2 20 4 20 8C20 12 14 15 12 20Z" fill="#C5A059" opacity="0.25"/></svg>

                <!-- Orangutan emblem -->
                <div class="an-start-emblem">
                    <img src="images/coin-front.jpg" alt="Orang Utan Capital" />
                </div>

                <!-- Title -->
                <h1 class="an-start-title">Tjoean</h1>

                <!-- Flourish -->
                <svg class="an-start-flourish" viewBox="0 0 240 20" fill="none">
                    <path d="M15 10C15 10 50 3 85 9C120 15 120 5 155 9C190 13 225 10 225 10" stroke="#C5A059" stroke-width="0.8" stroke-linecap="round"/>
                    <path d="M116 10L120 6L124 10L120 14Z" fill="#C5A059" opacity="0.5"/>
                    <circle cx="15" cy="10" r="1.5" fill="#C5A059" opacity="0.4"/>
                    <circle cx="225" cy="10" r="1.5" fill="#C5A059" opacity="0.4"/>
                </svg>

                <p class="an-start-subtitle">@(_selectedLanguage == Language.Indonesian ? "Simulasi Edukasi Investasi" : "Investment Education Simulation")</p>

                <!-- Form -->
                <div class="an-start-form">
                    <input type="text" @bind="_playerName" @bind:event="oninput" placeholder="@(_selectedLanguage == Language.Indonesian ? "Nama Anda" : "Your Name")" maxlength="20" class="an-input" />

                    <div class="an-toggle-row">
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="_isLightMode" />
                            <span class="an-toggle-slider"></span>
                        </label>
                        <div class="an-toggle-info">
                            <span class="an-toggle-label">@(_selectedLanguage == Language.Indonesian ? "Mode Ringan" : "Light Mode")</span>
                            <span class="an-toggle-desc">@(_selectedLanguage == Language.Indonesian ? "Penjelasan sederhana tanpa detail regulasi" : "Simple explanations without regulatory details")</span>
                        </div>
                        <!-- Language Dropdown -->
                        <div class="an-lang-dropdown-wrapper">
                            <button class="an-lang-dropdown-btn" @onclick="() => _showLangDropdown = !_showLangDropdown" title="Change Language">
                                @(_selectedLanguage == Language.Indonesian ? "🇮🇩" : "🇺🇸")
                            </button>
                            @if (_showLangDropdown)
                            {
                                <div class="an-lang-dropdown-menu">
                                    <button class="an-lang-dropdown-item @(_selectedLanguage == Language.Indonesian ? "selected" : "")"
                                            @onclick="() => { _selectedLanguage = Language.Indonesian; _showLangDropdown = false; }">
                                        🇮🇩 Bahasa Indonesia
                                    </button>
                                    <button class="an-lang-dropdown-item @(_selectedLanguage == Language.English ? "selected" : "")"
                                            @onclick="() => { _selectedLanguage = Language.English; _showLangDropdown = false; }">
                                        🇺🇸 English
                                    </button>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Mode Buttons with Icons -->
                    <div class="an-mode-buttons-icon">
                        <button class="an-mode-icon-btn solo-btn" @onclick="ShowTutorial" disabled="@(string.IsNullOrWhiteSpace(_playerName) || !_isConnected)" title="Solo Game">
                            <svg class="an-mode-icon" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                            </svg>
                            <span class="an-mode-label">SOLO</span>
                            @if (!_isConnected)
                            {
                                <span class="an-mode-status">@(_selectedLanguage == Language.Indonesian ? "Menghubungkan..." : "Connecting...")</span>
                            }
                        </button>
                        <button class="an-mode-icon-btn multi-btn" @onclick='() => _multiplayerScreen = "create-join"' disabled="@(string.IsNullOrWhiteSpace(_playerName) || !_isConnected)" title="Multiplayer Game">
                            <svg class="an-mode-icon" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                            </svg>
                            <span class="an-mode-label">GROUP</span>
                        </button>
                    </div>

                    @if (_connectionError != null)
                    {
                        <p style="color: #CD853F; font-size: 0.85rem; text-align: center; margin-top: 0.5rem; opacity: 0.9;">@_connectionError</p>
                    }
                </div>
            </div>

            <span class="an-start-footer">Orang Utan Capital</span>
        </div>
    }
    else if (_multiplayerScreen == "create-join")
    {
        <!-- Create or Join Room choice -->
        <div class="start-screen">
            <div class="an-start-frame">
                <div class="an-start-emblem">
                    <img src="images/coin-front.jpg" alt="Orang Utan Capital" />
                </div>
                <h1 class="an-start-title">Multiplayer</h1>
                <p class="an-start-subtitle">@(_selectedLanguage == Language.Indonesian ? "Bermain bersama teman!" : "Play with friends!")</p>

                <div class="an-start-form">
                    <div class="an-mode-buttons">
                        <button class="an-btn-start" @onclick='() => _multiplayerScreen = "create"'>
                            @(_selectedLanguage == Language.Indonesian ? "Buat Room" : "Create Room")
                        </button>
                        <button class="an-btn-start an-btn-multiplayer" @onclick='() => _multiplayerScreen = "join"'>
                            @(_selectedLanguage == Language.Indonesian ? "Gabung Room" : "Join Room")
                        </button>
                    </div>
                    <button class="an-btn-back" @onclick='() => _multiplayerScreen = "none"'>
                        @(_selectedLanguage == Language.Indonesian ? "Kembali" : "Back")
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_multiplayerScreen == "create")
    {
        <!-- Create Room Screen -->
        <div class="start-screen">
            <div class="an-start-frame">
                <h1 class="an-start-title">@(_selectedLanguage == Language.Indonesian ? "Buat Room" : "Create Room")</h1>
                <div class="an-start-form">
                    <div class="an-toggle-row">
                        <label class="toggle-switch">
                            <input type="checkbox" @bind="_isLightMode" />
                            <span class="an-toggle-slider"></span>
                        </label>
                        <div class="an-toggle-info">
                            <span class="an-toggle-label">@(_selectedLanguage == Language.Indonesian ? "Mode Ringan" : "Light Mode")</span>
                        </div>
                    </div>

                    <select class="an-input an-lang-select" @bind="_selectedLanguage">
                        <option value="@Language.Indonesian">🇮🇩 Bahasa Indonesia</option>
                        <option value="@Language.English">🇺🇸 English</option>
                    </select>

                    <div class="an-toggle-row">
                        <span class="an-toggle-label">@(_selectedLanguage == Language.Indonesian ? "Maks Pemain" : "Max Players"): @_maxPlayers</span>
                        <input type="range" min="2" max="4" @bind="_maxPlayers" class="an-slider" />
                    </div>

                    <button class="an-btn-start" @onclick="CreateRoom" disabled="@_isCreatingRoom">
                        @(_isCreatingRoom
                            ? (_selectedLanguage == Language.Indonesian ? "Membuat..." : "Creating...")
                            : (_selectedLanguage == Language.Indonesian ? "Buat Room" : "Create Room"))
                    </button>

                    @if (_roomError != null)
                    {
                        <p class="room-error">@_roomError</p>
                    }

                    <button class="an-btn-back" @onclick='() => _multiplayerScreen = "create-join"'>
                        @(_selectedLanguage == Language.Indonesian ? "Kembali" : "Back")
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_multiplayerScreen == "join")
    {
        <!-- Join Room Screen -->
        <div class="start-screen">
            <div class="an-start-frame">
                <h1 class="an-start-title">@(_selectedLanguage == Language.Indonesian ? "Gabung Room" : "Join Room")</h1>
                <div class="an-start-form">
                    <input type="text" @bind="_roomCodeInput" @bind:event="oninput"
                           placeholder="@(_selectedLanguage == Language.Indonesian ? "Kode Room (6 karakter)" : "Room Code (6 characters)")"
                           maxlength="6" class="an-input room-code-input" style="text-transform: uppercase; text-align: center; font-size: 1.5rem; letter-spacing: 0.3rem;" />

                    <button class="an-btn-start" @onclick="JoinRoom" disabled="@(_roomCodeInput?.Length != 6 || _isJoiningRoom)">
                        @(_isJoiningRoom
                            ? (_selectedLanguage == Language.Indonesian ? "Bergabung..." : "Joining...")
                            : (_selectedLanguage == Language.Indonesian ? "Gabung" : "Join"))
                    </button>

                    @if (_roomError != null)
                    {
                        <p class="room-error">@_roomError</p>
                    }

                    <button class="an-btn-back" @onclick='() => _multiplayerScreen = "create-join"'>
                        @(_selectedLanguage == Language.Indonesian ? "Kembali" : "Back")
                    </button>
                </div>
            </div>
        </div>
    }
    else if (_multiplayerScreen == "lobby")
    {
        <!-- Room Lobby -->
        <div class="start-screen">
            <div class="an-start-frame" style="max-width: 500px;">
                <h1 class="an-start-title">@(_selectedLanguage == Language.Indonesian ? "Lobby" : "Lobby")</h1>

                @if (_currentRoom != null)
                {
                    <div class="room-code-display">
                        <span class="room-code-label">@(_selectedLanguage == Language.Indonesian ? "Kode Room" : "Room Code")</span>
                        <span class="room-code-value">@_currentRoom.RoomCode</span>
                    </div>

                    <div class="room-settings">
                        <span>@(_currentRoom.AgeMode == AgeMode.Kids ? (_selectedLanguage == Language.Indonesian ? "Mode Ringan" : "Light Mode") : "Normal") | @(_currentRoom.Language == Language.Indonesian ? "ID" : "EN") | @_currentRoom.MaxPlayers @(_selectedLanguage == Language.Indonesian ? "pemain" : "players")</span>
                    </div>

                    <div class="player-list">
                        @foreach (var player in _currentRoom.Players)
                        {
                            <div class="player-item @(player.IsHost ? "player-host" : "")">
                                <span class="player-name-lobby">
                                    @if (player.IsHost) { <span class="host-badge">HOST</span> }
                                    @player.PlayerName
                                </span>
                                <span class="player-ready @(player.IsReady ? "ready" : "not-ready")">
                                    @(player.IsReady
                                        ? (_selectedLanguage == Language.Indonesian ? "Siap" : "Ready")
                                        : (_selectedLanguage == Language.Indonesian ? "Belum Siap" : "Not Ready"))
                                </span>
                            </div>
                        }
                        @for (int i = _currentRoom.Players.Count; i < _currentRoom.MaxPlayers; i++)
                        {
                            <div class="player-item player-empty">
                                <span class="player-name-lobby">@(_selectedLanguage == Language.Indonesian ? "Menunggu pemain..." : "Waiting for player...")</span>
                            </div>
                        }
                    </div>

                    <div class="lobby-actions">
                        @if (!_isHost)
                        {
                            <button class="an-btn-start @(_isReady ? "btn-ready-active" : "")" @onclick="ToggleReady">
                                @(_isReady
                                    ? (_selectedLanguage == Language.Indonesian ? "Batal Siap" : "Unready")
                                    : (_selectedLanguage == Language.Indonesian ? "Siap" : "Ready"))
                            </button>
                        }
                        @if (_isHost)
                        {
                            <button class="an-btn-start" @onclick="StartMultiplayerGame"
                                    disabled="@(!_currentRoom.Players.All(p => p.IsReady) || _currentRoom.Players.Count < 2)">
                                @(_selectedLanguage == Language.Indonesian ? "Mulai Permainan" : "Start Game")
                            </button>
                        }
                        <button class="an-btn-back" @onclick="LeaveRoom">
                            @(_selectedLanguage == Language.Indonesian ? "Keluar Room" : "Leave Room")
                        </button>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="game-screen">
            <!-- Header -->
            <header class="game-header">
                <div class="header-left">
                    <h1><img class="header-logo" src="images/coin-front.jpg" alt="Logo" /> TJOEAN</h1>
                    <span class="player-name">@UIIcon("user") @_gameState.PlayerId</span>
                </div>
                <div class="header-center">
                    <div class="time-display">
                        <span class="year">@UIIcon("calendar") @GetText("Tahun", "Tahun", "Year", "Year") @_gameState.CurrentYear / 15</span>
                        <span class="month">@UIIcon("month") @GetText("Bulan", "Bulan", "Month", "Month") @_gameState.CurrentMonth</span>
                    </div>
                    <div class="progress-container">
                        <div class="progress-label">@GetText("Tahun", "Tahun", "Year", "Year")</div>
                        <div class="progress-bar year-progress">
                            <div class="progress-fill" style="width: @((_gameState.CurrentYear - 1) * 100.0 / 15 + (_gameState.CurrentMonth - 1) * 100.0 / 15 / 12)%"></div>
                        </div>
                        <div class="progress-label">@GetText("Bulan", "Bulan", "Month", "Month")</div>
                        <div class="progress-bar month-progress">
                            <div class="progress-fill month-fill" style="width: @_gameState.MonthProgress%"></div>
                        </div>
                    </div>
                </div>
                <div class="header-right">
                    <button class="btn-icon pause-play-btn" @onclick="TogglePause"
                            disabled="@(_gameState.IsEventPending || _gameState.IsGameOver)">
                        @if (_isPaused)
                        {
                            <svg class="icon-play" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                                <path d="M8 5v14l11-7z"/>
                            </svg>
                            <span class="btn-label">@GetText("Lanjut", "Lanjutkan", "Play", "Resume")</span>
                        }
                        else
                        {
                            <svg class="icon-pause" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
                                <path d="M6 4h4v16H6zm8 0h4v16h-4z"/>
                            </svg>
                            <span class="btn-label">@GetText("Jeda", "Jeda", "Pause", "Pause")</span>
                        }
                    </button>
                    <button class="btn-icon" @onclick="RestartGame" title="@GetText("Mulai Ulang", "Mulai Ulang", "Restart", "Restart")">
                        ↻
                    </button>
                </div>
            </header>

            <!-- Multiplayer Leaderboard Bar -->
            @if (_gameState.IsMultiplayer && _leaderboard != null && _leaderboard.Count > 0)
            {
                <div class="mp-leaderboard-bar">
                    @foreach (var entry in _leaderboard)
                    {
                        <div class="mp-lb-entry @(entry.PlayerName == _playerName ? "mp-lb-self" : "") @(entry.IsBot ? "mp-lb-bot" : "")">
                            <span class="mp-lb-rank">#@entry.Rank</span>
                            <span class="mp-lb-name">@(entry.IsBot ? "Bot" : entry.PlayerName)</span>
                            <span class="mp-lb-worth">Rp @entry.NetWorth.ToString("N0")</span>
                        </div>
                    }
                </div>
            }

            <!-- New Unlock Banner -->
            @if (!string.IsNullOrEmpty(_gameState.NewUnlockMessage))
            {
                <div class="event-banner unlock">
                    <span class="event-icon">@UIIcon("unlock")</span>
                    <span class="event-text">@_gameState.NewUnlockMessage</span>
                </div>
            }

            <!-- Main Content -->
            <main class="game-main">
                <!-- Left Panel: Balance & Portfolio -->
                <section class="panel panel-left">
                    <div class="balance-networth-compact">
                        <div class="balance-row">
                            <span class="label">@UIIcon("cash") @GetText("Kas", "Kas", "Cash", "Cash")</span>
                            <span class="amount">Rp @_gameState.CashBalance.ToString("N0")</span>
                        </div>
                        <div class="balance-row networth-total">
                            <span class="label">@UIIcon("trophy") @GetText("Kekayaan", "Kekayaan Bersih", "Net Worth", "Net Worth")</span>
                            <span class="amount">Rp @_gameState.NetWorth.ToString("N0")</span>
                        </div>
                        <div class="breakdown-grid">
                            <div class="breakdown-item" title="@GetText("Tabungan", "Tabungan", "Savings", "Savings")">
                                <span class="icon">@UIIcon("savings")</span>
                                <span class="value">@_gameState.TotalSavingsValue.ToString("N0")</span>
                            </div>
                            <div class="breakdown-item" title="@GetText("Investasi (Saham, Emas, Reksa Dana, Kripto, Urun Dana)", "Portofolio Investasi", "Investments (Stocks, Gold, Mutual Funds, Crypto, Crowdfunding)", "Investment Portfolio")">
                                <span class="icon">@UIIcon("chart")</span>
                                <span class="value">@_gameState.TotalPortfolioValue.ToString("N0")</span>
                            </div>
                            <div class="breakdown-item" title="@GetText("Deposito", "Deposito", "Certificate of Deposit", "Certificate of Deposit")">
                                <span class="icon">@UIIcon("bank")</span>
                                <span class="value">@_gameState.TotalDepositoValue.ToString("N0")</span>
                            </div>
                            <div class="breakdown-item" title="@GetText("Obligasi", "Obligasi", "Bonds", "Bonds")">
                                <span class="icon">@UIIcon("scroll")</span>
                                <span class="value">@_gameState.TotalBondValue.ToString("N0")</span>
                            </div>
                        </div>
                    </div>

                    <!-- Savings Account Section -->
                    @if (_gameState.UnlockedAssets.Contains("tabungan"))
                    {
                        <div class="savings-section-compact">
                            <div class="section-header-compact">
                                <h4>@Icon("tabungan") @GetText("Tabungan", "Tabungan", "Savings", "Savings")</h4>
                                <button class="btn-info-mini" @onclick='() => ShowAssetInfo("tabungan")' title="Info">?</button>
                            </div>
                            <div class="savings-balance-compact">
                                Rp @FormatCurrency(_gameState.SavingsAccount?.Balance ?? 0)
                            </div>
                            <div class="savings-controls">
                                <div class="numeric-spin-group">
                                    <input type="text" inputmode="numeric" value="@_savingsAmountDisplay" @oninput="OnSavingsInput" placeholder="Rp 1.000.000" class="savings-input-compact" />
                                    <div class="spin-buttons">
                                        <button class="spin-btn spin-up" @onclick="() => SpinInput(ref _savingsAmount, ref _savingsAmountDisplay, 1_000_000, true)" title="+Rp 1.000.000">&#9650;</button>
                                        <button class="spin-btn spin-down" @onclick="() => SpinInput(ref _savingsAmount, ref _savingsAmountDisplay, 1_000_000, false)" title="-Rp 1.000.000">&#9660;</button>
                                    </div>
                                </div>
                                <button class="btn-action-compact deposit" @onclick="DepositToSavings"
                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || _savingsAmount <= 0 || _savingsAmount > _gameState.CashBalance)">
                                    @GetText("Setor", "Setor", "Deposit", "Deposit")
                                </button>
                                <button class="btn-action-compact withdraw" @onclick="WithdrawFromSavings"
                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || _savingsAmount <= 0 || _savingsAmount > (_gameState.SavingsAccount?.Balance ?? 0))">
                                    @GetText("Tarik", "Tarik", "Withdraw", "Withdraw")
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Portfolio Section -->
                    <div class="portfolio-section">
                        <h3>@GetText("Investasimu", "Portofolio Anda", "Your Portfolio", "Your Portfolio")</h3>
                        @if (_gameState.Portfolio.Any())
                        {
                            <div class="portfolio-list">
                                @foreach (var item in _gameState.Portfolio.OrderBy(p => p.AssetType == "obligasi" ? 1 : 0))
                                {
                                    <div class="portfolio-item">
                                        <div class="item-header">
                                            <span class="item-name">@Icon(item.AssetType) @item.DisplayName @(string.IsNullOrEmpty(item.Ticker) ? "" : $"({item.Ticker})")</span>
                                            <span class="item-units">
                                                @if (item.AssetType == "crypto")
                                                {
                                                    @item.Units.ToString("F4") <text> </text> @item.Ticker
                                                }
                                                else if (item.AssetType == "saham")
                                                {
                                                    @((item.Units / 100).ToString("N0")) <text> lot</text>
                                                }
                                                else if (item.AssetType == "emas")
                                                {
                                                    @item.Units.ToString("N0") <text> g (@GetText("gram", "gram", "grams", "grams"))</text>
                                                }
                                                else
                                                {
                                                    @item.Units.ToString("N0") <text> @GetText("unit", "unit", "units", "units")</text>
                                                }
                                            </span>
                                        </div>
                                        <div class="item-values">
                                            <span class="item-value">Rp @item.TotalValue.ToString("N0")</span>
                                            <span class="item-profit @(item.ProfitLoss >= 0 ? "positive" : "negative")">
                                                @(item.ProfitLoss >= 0 ? "▲+" : "▼")@item.ProfitLossPercent.ToString("F1")%
                                            </span>
                                        </div>
                                        @if (item.AssetType == "saham")
                                        {
                                            <div class="item-avg-cost">
                                                <span>@GetText("Harga Rata-rata", "Harga Rata-rata", "Average Cost", "Average Cost"): Rp @((item.TotalCost / Math.Max(item.Units, 1)).ToString("N0"))/@GetText("lembar", "lembar", "share", "share")</span>
                                            </div>
                                        }
                                        <div class="item-buttons">
                                            @if (item.AssetType == "saham")
                                            {
                                                <button class="btn-sell" @onclick="() => SellStock(item.Ticker, 1)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || item.Units < 100)">
                                                    @GetText("Jual 1 Lot", "Jual 1 Lot", "Sell 1 Lot", "Sell 1 Lot")
                                                </button>
                                                <button class="btn-sell" @onclick="() => SellStock(item.Ticker, 5)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || item.Units < 500)">
                                                    @GetText("Jual 5 Lot", "Jual 5 Lot", "Sell 5 Lot", "Sell 5 Lot")
                                                </button>
                                                <button class="btn-sell-all" @onclick="() => SellAllStock(item.Ticker)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || item.Units < 100)">
                                                    @GetText("Jual Semua", "Jual Semua", "Sell All", "Sell All")
                                                </button>
                                            }
                                            else if (item.AssetType == "crypto")
                                            {
                                                <button class="btn-sell" @onclick="() => SellCrypto(item.Ticker, 1_000_000)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || item.TotalValue < 1_000_000)">
                                                    @GetText("Jual Rp 1 Juta", "Jual Rp 1 Juta", "Sell Rp 1 Million", "Sell Rp 1 Million")
                                                </button>
                                                <button class="btn-sell-all" @onclick="() => SellAllCrypto(item.Ticker)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending)">
                                                    @GetText("Jual Semua", "Jual Semua", "Sell All", "Sell All")
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn-sell" @onclick="() => SellAsset(item.AssetType)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending)">
                                                    @GetText("Jual 1", "Jual 1", "Sell 1", "Sell 1")
                                                </button>
                                                <button class="btn-sell-all" @onclick="() => SellAllAssets(item.AssetType)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending)">
                                                    @GetText("Jual Semua", "Jual Semua", "Sell All", "Sell All")
                                                </button>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else
                        {
                            <p class="empty-portfolio">@GetText("🐣 Belum punya investasi. Ayo mulai nabung!", "Belum ada investasi dalam portofolio.", "🐣 No investments yet. Start investing!", "No investments in your portfolio.")</p>
                        }
                    </div>

                    <!-- Deposito Section -->
                    @if (_gameState.Depositos.Any())
                    {
                        <div class="deposito-section">
                            <h3>@GetText("Deposito", "Deposito", "Certificate of Deposit", "Certificate of Deposit")</h3>
                            <div class="deposito-list">
                                @foreach (var deposito in _gameState.Depositos)
                                {
                                    <div class="deposito-item">
                                        <div class="deposito-info">
                                            <div class="item-header">
                                                <span class="item-name">@Icon("deposito") @GetText("Deposito", "Deposito", "Certificate of Deposit", "Certificate of Deposit") @deposito.PeriodMonths @GetText("Bulan", "Bulan", "Months", "Months")</span>
                                                <span class="item-units">@((deposito.InterestRate * 100).ToString("F1"))% /@GetText("tahun", "tahun", "year", "year")</span>
                                            </div>
                                            <div class="item-values">
                                                <span class="item-value">Rp @deposito.CurrentValue.ToString("N0")</span>
                                                <span class="deposito-period">⏳ @deposito.MonthsRemaining @GetText("bulan lagi", "bulan lagi", "months left", "months left")</span>
                                            </div>
                                        </div>
                                        <div class="deposito-progress">
                                            <div class="deposito-progress-fill" style="width: @deposito.ProgressPercent%"></div>
                                        </div>
                                        <div class="deposito-aro-toggle">
                                            <label class="aro-checkbox-label" title="@GetText("Otomatis investasi ulang saat jatuh tempo", "Otomatis investasi ulang saat jatuh tempo", "Automatically re-invest at maturity", "Automatically re-invest at maturity")">
                                                <input type="checkbox" checked="@deposito.AutoRollOver"
                                                       @onchange="() => ToggleDepositoAutoRollOver(deposito.Id)"
                                                       disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending)" />
                                                <span class="aro-label">@UIIcon("coin") @GetText("Roll Over Otomatis", "Roll Over Otomatis", "Auto Roll Over", "Auto Roll Over")</span>
                                            </label>
                                        </div>
                                        @if (deposito.IsMatured)
                                        {
                                            <div class="deposito-maturity">@UIIcon("trophy") @GetText("Sudah Jatuh Tempo!", "Sudah Jatuh Tempo!", "Matured!", "Matured!")</div>
                                            <div class="deposito-buttons">
                                                <button class="btn-withdraw" @onclick="() => WithdrawDeposito(deposito.Id, false)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending)">
                                                    @UIIcon("coin") @GetText("Ambil", "Ambil", "Withdraw", "Withdraw") Rp @deposito.MaturityValue.ToString("N0")
                                                </button>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="deposito-buttons">
                                                <button class="btn-withdraw early" @onclick="() => WithdrawDeposito(deposito.Id, true)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending)"
                                                        title="@GetText("Kena denda 50% bunga karena ambil sebelum waktunya", "Kena denda 50% bunga karena ambil sebelum waktunya", "Early withdrawal penalty: 50% of accrued interest", "Early withdrawal penalty: 50% of accrued interest")">
                                                    ⚠️ @GetText("Ambil Paksa (Kena Denda!)", "Ambil Paksa (Kena Denda!)", "Early Withdrawal (Penalty!)", "Early Withdrawal (Penalty!)")
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- Bonds Section -->
                    @if (_gameState.Bonds.Any())
                    {
                        <div class="bond-section">
                            <h3>@GetText("Obligasi Negara", "Obligasi Negara", "Government Bonds", "Government Bonds")</h3>
                            <div class="bond-list">
                                @foreach (var bond in _gameState.Bonds)
                                {
                                    <div class="bond-item">
                                        <div class="bond-info">
                                            <div class="item-header">
                                                <span class="item-name">@Icon("obligasi") @bond.BondName</span>
                                                <span class="item-units">@((bond.CouponRate * 100).ToString("F1"))% @GetText("kupon", "kupon", "coupon", "coupon")</span>
                                            </div>
                                            <div class="item-values">
                                                <span class="item-value">Rp @bond.CurrentValue.ToString("N0")</span>
                                                <span class="bond-period">⏳ @bond.MonthsRemaining @GetText("bulan lagi", "bulan lagi", "months left", "months left")</span>
                                            </div>
                                            <div class="bond-coupon-earned">
                                                @GetText("Kupon", "Kupon", "Coupon", "Coupon"): +Rp @bond.TotalCouponEarned.ToString("N0")
                                            </div>
                                        </div>
                                        <div class="bond-progress">
                                            <div class="bond-progress-fill" style="width: @bond.ProgressPercent%"></div>
                                        </div>
                                        @if (bond.IsMatured)
                                        {
                                            <div class="bond-maturity">@UIIcon("trophy") @GetText("Jatuh Tempo!", "Jatuh Tempo!", "Matured!", "Matured!")</div>
                                            <div class="bond-buttons">
                                                <button class="btn-withdraw" @onclick="() => WithdrawBond(bond.Id)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending)">
                                                    @UIIcon("coin") @GetText("Ambil", "Ambil", "Withdraw", "Withdraw") Rp @bond.CurrentValue.ToString("N0")
                                                </button>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </section>

                <!-- Center Panel: Market -->
                <section class="panel panel-center">
                    <h2>@GetText("Pasar Investasi", "Pasar Investasi", "Investment Market", "Investment Market")</h2>

                    <!-- Deposito Purchase Section -->
                    @if (_gameState.UnlockedAssets.Contains("deposito") && _depositoRates != null && _depositoRates.Any())
                    {
                        <div class="deposito-purchase-section">
                            <div class="section-header">
                                <h3>@GetText("Buka Deposito Baru", "Buka Deposito Baru", "Certificate of Deposit", "Certificate of Deposit")</h3>
                                <button class="btn-info-inline" @onclick='() => ShowAssetInfo("deposito")' title="Info">
                                    ❓
                                </button>
                            </div>
                            <p style="font-size: 0.85rem; color: #636E72; margin-bottom: 0.8rem; text-align: center;">
                                @GetText("💡 Deposito itu seperti celengan terkunci - uangmu aman dan dapat bonus bunga!", "💡 Deposito - suku bunga tetap dengan jaminan keuntungan", "💡 Fixed interest rate with guaranteed returns", "💡 Fixed interest rate with guaranteed returns")
                            </p>
                            <div class="deposito-rates">
                                @foreach (var rate in _depositoRates)
                                {
                                    <div class="deposito-rate-card @(_selectedDepositoPeriod == rate.PeriodMonths ? "selected" : "")"
                                         @onclick="() => _selectedDepositoPeriod = rate.PeriodMonths">
                                        <span class="period">@rate.PeriodName</span>
                                        <span class="rate">@((rate.AnnualRate * 100).ToString("F1"))%</span>
                                        <span class="min-deposit">Min: Rp @rate.MinimumDeposit.ToString("N0")</span>
                                    </div>
                                }
                            </div>
                            <div class="deposito-auto-rollover">
                                <label class="auto-rollover-checkbox" title="@GetText("Otomatis investasi ulang saat jatuh tempo dengan bunga compound", "Otomatis investasi ulang saat jatuh tempo", "Automatically re-invest when matured with compound interest", "Automatically re-invest at maturity")">
                                    <input type="checkbox" @bind="_depositoAutoRollOver" />
                                    <span class="checkbox-label">
                                        @UIIcon("coin") @GetText("Roll Over Otomatis", "Roll Over Otomatis", "Automatic Roll Over", "Automatic Roll Over")
                                    </span>
                                    <span class="info-icon info-icon-clickable" @onclick="() => _showAroInfo = true" @onclick:stopPropagation="true">ℹ️</span>
                                </label>
                            </div>
                            <div class="deposito-amount-input">
                                <div class="numeric-spin-group">
                                    <input type="text" inputmode="numeric" value="@_depositoAmountDisplay" @oninput="OnDepositoInput" placeholder="Min Rp 1.000.000" />
                                    <div class="spin-buttons">
                                        <button class="spin-btn spin-up" @onclick="() => SpinInput(ref _depositoAmount, ref _depositoAmountDisplay, 1_000_000, true)" title="+Rp 1.000.000">&#9650;</button>
                                        <button class="spin-btn spin-down" @onclick="() => SpinInput(ref _depositoAmount, ref _depositoAmountDisplay, 1_000_000, false)" title="-Rp 1.000.000">&#9660;</button>
                                    </div>
                                </div>
                                <button class="btn-buy" @onclick="BuyDeposito"
                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || _selectedDepositoPeriod == 0 || _depositoAmount < 1000000 || _depositoAmount > _gameState.CashBalance)">
                                    @UIIcon("lock") @GetText("Kunci Uang", "Kunci Uang", "Lock Funds", "Lock Funds")
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Bond Purchase Section -->
                    @if (_gameState.UnlockedAssets.Contains("obligasi") && _bondRates != null && _bondRates.Any())
                    {
                        <div class="bond-purchase-section">
                            <div class="section-header">
                                <h3>@GetText("Beli Obligasi Negara", "Beli Obligasi Negara", "Government Bonds", "Government Bonds")</h3>
                                <button class="btn-info-inline" @onclick='() => ShowAssetInfo("obligasi")' title="Info">
                                    ❓
                                </button>
                            </div>
                            <p style="font-size: 0.85rem; color: #636E72; margin-bottom: 0.8rem; text-align: center;">
                                @GetText("💡 Obligasi adalah surat utang negara - aman dan dapat kupon tiap bulan!", "💡 Obligasi - risiko rendah dengan pembayaran kupon bulanan", "💡 Low risk with monthly coupon payments", "💡 Low risk with monthly coupon payments")
                            </p>
                            <div class="bond-rates">
                                @foreach (var rate in _bondRates)
                                {
                                    <div class="bond-rate-card @(_selectedBondType == rate.BondType ? "selected" : "")"
                                         @onclick="() => _selectedBondType = rate.BondType">
                                        <span class="bond-type">@rate.BondType</span>
                                        <span class="bond-period">@rate.PeriodName</span>
                                        <span class="bond-coupon">@((rate.CouponRate * 100).ToString("F1"))% @GetText("kupon", "kupon", "coupon", "coupon")</span>
                                        <span class="min-invest">Min: Rp @rate.MinimumInvestment.ToString("N0")</span>
                                    </div>
                                }
                            </div>
                            <div class="bond-amount-input">
                                <div class="numeric-spin-group">
                                    <input type="text" inputmode="numeric" value="@_bondAmountDisplay" @oninput="OnBondInput" placeholder="Min Rp 1.000.000" />
                                    <div class="spin-buttons">
                                        <button class="spin-btn spin-up" @onclick="() => SpinInput(ref _bondAmount, ref _bondAmountDisplay, 1_000_000, true)" title="+Rp 1.000.000">&#9650;</button>
                                        <button class="spin-btn spin-down" @onclick="() => SpinInput(ref _bondAmount, ref _bondAmountDisplay, 1_000_000, false)" title="-Rp 1.000.000">&#9660;</button>
                                    </div>
                                </div>
                                <button class="btn-buy" @onclick="BuyBond"
                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || string.IsNullOrEmpty(_selectedBondType) || _bondAmount < 1000000 || _bondAmount > _gameState.CashBalance)">
                                    @Icon("obligasi") @GetText("Beli Obligasi", "Beli Obligasi", "Buy Bond", "Buy Bond")
                                </button>
                            </div>
                        </div>
                    }

                    <!-- Individual Stocks Section -->
                    @if (_gameState.UnlockedAssets.Contains("saham") && _gameState.AvailableStocks.Any())
                    {
                        <div class="stocks-section">
                            <div class="section-header">
                                <h3>@Icon("saham") @GetText("Saham Individual", "Saham Individual", "Individual Stocks", "Individual Stocks")</h3>
                                <button class="btn-info-inline" @onclick='() => ShowAssetInfo("saham")' title="Info">
                                    ❓
                                </button>
                            </div>
                            <p class="section-tip">
                                @GetText("💡 Harga saham berubah setiap 2 bulan. Dividen dibayar setiap akhir tahun!",
                                         "💡 Harga saham berubah setiap 2 bulan. Dividen dibayar setiap akhir tahun!",
                                         "💡 Stock prices update every 2 months. Dividends paid annually!",
                                         "💡 Stock prices update every 2 months. Dividends paid annually!")
                            </p>
                            <div class="stocks-list">
                                @foreach (var stock in _gameState.AvailableStocks)
                                {
                                    <div class="stock-row compact">
                                        <div class="stock-info">
                                            <div class="stock-main">
                                                <span class="stock-ticker-badge">@stock.Ticker</span>
                                                <div class="stock-details">
                                                    <span class="stock-name">@stock.CompanyName</span>
                                                    <span class="stock-meta">@stock.Sector @if(stock.PaysDividend) { <span class="dividend-badge" title="@GetText("Dividen tahunan", "Dividen tahunan", "Annual dividend", "Annual dividend")">@UIIcon("coin") @((stock.DividendYield * 100).ToString("F1"))%</span> }</span>
                                                </div>
                                            </div>
                                            <div class="stock-price-info compact">
                                                <span class="stock-price-value">Rp @stock.CurrentPrice.ToString("N0")</span>
                                                <span class="stock-change @(stock.Change >= 0 ? "positive" : "negative")">
                                                    @(stock.Change >= 0 ? "+" : "")@stock.ChangePercent.ToString("F1")%
                                                </span>
                                            </div>
                                        </div>
                                        <div class="stock-actions-row compact">
                                            <span class="lot-price">1 Lot = Rp @((stock.CurrentPrice * 100).ToString("N0"))</span>
                                            <div class="quick-buy-buttons">
                                                <button class="btn-quick-lot" @onclick="() => BuyStock(stock.Ticker, 5)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || (stock.CurrentPrice * 100 * 5) > _gameState.CashBalance)">
                                                    5 @GetText("Lot", "Lot", "Lot", "Lot")
                                                </button>
                                                <button class="btn-quick-lot" @onclick="() => BuyStock(stock.Ticker, 25)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || (stock.CurrentPrice * 100 * 25) > _gameState.CashBalance)">
                                                    25 @GetText("Lot", "Lot", "Lot", "Lot")
                                                </button>
                                                <button class="btn-quick-lot" @onclick="() => BuyStock(stock.Ticker, 100)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || (stock.CurrentPrice * 100 * 100) > _gameState.CashBalance)">
                                                    100 @GetText("Lot", "Lot", "Lot", "Lot")
                                                </button>
                                                <button class="btn-quick-lot" @onclick="() => BuyStock(stock.Ticker, 500)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || (stock.CurrentPrice * 100 * 500) > _gameState.CashBalance)">
                                                    500 @GetText("Lot", "Lot", "Lot", "Lot")
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <!-- General Market Grid (Index Fund, Gold, Crypto, Crowdfunding) -->
                    <div class="market-grid">
                        @* Regular Assets (Index Fund, Gold, Crowdfunding) *@
                        @foreach (var price in _gameState.CurrentPrices.Where(p => _gameState.UnlockedAssets.Contains(p.AssetType) && !new[] { "tabungan", "deposito", "obligasi", "saham", "crypto", "crowdfunding" }.Contains(p.AssetType)))
                        {
                            var asset = _assets?.GetValueOrDefault(price.AssetType);
                            var isGold = price.AssetType == "emas";
                            var isReksadana = price.AssetType == "reksadana";
                            <div class="market-card @GetRiskClass(asset?.RiskLevel)">
                                <div class="card-header">
                                    <span class="asset-name">@Icon(price.AssetType) @GetAssetDisplayName(asset, price.DisplayName)</span>
                                    <div class="card-actions">
                                        <button class="btn-info" @onclick="() => ShowAssetInfo(price.AssetType)" title="Info">
                                            &#x2753;
                                        </button>
                                        <span class="risk-badge">@(asset?.RiskLevel ?? "?")</span>
                                    </div>
                                </div>
                                @if (!isReksadana)
                                {
                                    <div class="card-price">
                                        <span class="price">Rp @price.Price.ToString("N0")@(isGold ? "/g" : "")</span>
                                        @if (price.ShowChange)
                                        {
                                            <span class="change @(price.Change >= 0 ? "positive" : "negative")">
                                                @(price.Change >= 0 ? "+" : "")@price.ChangePercent.ToString("F2")%
                                            </span>
                                        }
                                    </div>
                                }
                                @if (asset != null)
                                {
                                    <p class="card-desc">@GetAssetDescription(asset)</p>
                                }
                                @if (isGold)
                                {
                                    <div class="gold-buy-buttons">
                                        <button class="btn-buy btn-buy-1g" @onclick="() => BuyGoldByGrams(1)"
                                                disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || _gameState.CashBalance < price.Price)">
                                            @Icon("emas") @GetText("1g", "1g", "1g", "1g")
                                        </button>
                                        <button class="btn-buy btn-buy-1g" @onclick="() => BuyGoldByGrams(3)"
                                                disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || _gameState.CashBalance < price.Price * 3)">
                                            @Icon("emas") @GetText("3g", "3g", "3g", "3g")
                                        </button>
                                        <button class="btn-buy btn-buy-1g" @onclick="() => BuyGoldByGrams(5)"
                                                disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || _gameState.CashBalance < price.Price * 5)">
                                            @Icon("emas") @GetText("5g", "5g", "5g", "5g")
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn-buy @(isReksadana ? "btn-buy-half" : "")" @onclick="() => BuyAsset(price.AssetType)"
                                            disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || _gameState.CashBalance < 1_000_000)">
                                        &#x1F6D2; @GetText("Beli Rp 1 Juta", "Beli Rp 1 Juta", "Buy Rp 1 Million", "Buy Rp 1 Million")
                                    </button>
                                }
                            </div>
                        }

                        @* Crypto Assets (BTC, ETH, DOGE) - Grouped with black background *@
                        @if (_gameState.UnlockedAssets.Contains("crypto") && _gameState.AvailableCryptos.Any())
                        {
                            var cryptoAsset = _assets?.GetValueOrDefault("crypto");
                            <div class="crypto-group-container">
                                <div class="crypto-group-header">
                                    <span class="crypto-group-title">@Icon("crypto") @GetText("Aset Kripto", "Aset Kripto", "Crypto Assets", "Crypto Assets")</span>
                                    <div class="crypto-group-actions">
                                        <button class="btn-info crypto-info-btn" @onclick='() => ShowAssetInfo("crypto")' title="Info">
                                            &#x2753;
                                        </button>
                                        <span class="risk-badge extreme">@(cryptoAsset?.RiskLevel ?? "5")</span>
                                    </div>
                                </div>
                                <p class="crypto-group-warning">⚠️ @GetText("SANGAT BERISIKO! Bisa untung besar atau kehilangan segalanya!", "SANGAT BERISIKO!", "EXTREMELY RISKY! Can make huge gains or lose everything!", "EXTREMELY RISKY!")</p>
                                <div class="crypto-coins-row">
                                    @foreach (var crypto in _gameState.AvailableCryptos)
                                    {
                                        <div class="crypto-coin-card @(crypto.Symbol == "DOGE" ? "doge-crypto" : "")">
                                            <div class="crypto-coin-header">
                                                <span class="crypto-symbol">@crypto.Symbol</span>
                                                <span class="crypto-name">@crypto.Name</span>
                                            </div>
                                            <div class="crypto-coin-price">
                                                <span class="price">Rp @crypto.CurrentPrice.ToString("N0")</span>
                                                <span class="change @(crypto.Change >= 0 ? "positive" : "negative")">
                                                    @(crypto.Change >= 0 ? "+" : "")@crypto.ChangePercent.ToString("F1")%
                                                </span>
                                            </div>
                                            <div class="crypto-buy-controls">
                                                <div class="numeric-spin-group crypto-spin">
                                                    <input type="text" inputmode="numeric" value="@GetCryptoAmountDisplay(crypto.Symbol)" @oninput="(e) => OnCryptoInput(e, crypto.Symbol)"
                                                           placeholder="Rp 1.000.000" class="crypto-input" />
                                                    <div class="spin-buttons">
                                                        <button class="spin-btn spin-up" @onclick="() => SpinDictInput(_cryptoAmounts, crypto.Symbol, 1_000_000, true, 1_000_000)" title="+Rp 1.000.000">&#9650;</button>
                                                        <button class="spin-btn spin-down" @onclick="() => SpinDictInput(_cryptoAmounts, crypto.Symbol, 1_000_000, false, 1_000_000)" title="-Rp 1.000.000">&#9660;</button>
                                                    </div>
                                                </div>
                                                <button class="crypto-buy-btn" @onclick="() => BuyCrypto(crypto.Symbol)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || GetCryptoAmount(crypto.Symbol) < 1000000 || GetCryptoAmount(crypto.Symbol) > _gameState.CashBalance)">
                                                    @GetText("Beli", "Beli", "Buy", "Buy")
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        @* Crowdfunding Projects - Grouped in a row *@
                        @if (_gameState.UnlockedAssets.Contains("crowdfunding") && _gameState.AvailableCrowdfunding.Any())
                        {
                            var cfAsset = _assets?.GetValueOrDefault("crowdfunding");
                            <div class="crowdfunding-group-container">
                                <div class="crowdfunding-group-header">
                                    <span class="crowdfunding-group-title">@Icon("crowdfunding") @GetText("Urun Dana / Crowdfunding", "Urun Dana", "Crowdfunding", "Securities Crowdfunding")</span>
                                    <div class="crowdfunding-group-actions">
                                        <button class="btn-info" @onclick='() => ShowAssetInfo("crowdfunding")' title="Info">
                                            &#x2753;
                                        </button>
                                        <span class="risk-badge high">@(cfAsset?.RiskLevel ?? "4")</span>
                                    </div>
                                </div>
                                <p class="crowdfunding-group-warning">⚠️ @GetText("Uang terkunci selama masa investasi. 20% proyek bisa GAGAL!", "Uang terkunci selama masa investasi. 20% proyek bisa GAGAL!", "Locked during investment period. 20% of projects may FAIL!", "Locked during investment period. 20% of projects may FAIL!")</p>
                                <div class="crowdfunding-projects-row">
                                    @foreach (var project in _gameState.AvailableCrowdfunding.Where(p => p.IsActive))
                                    {
                                        var projectIcon = project.ProjectType switch
                                        {
                                            "Commodities" => "☕",
                                            "Agriculture" => "🌱",
                                            "Tech Startup" => "💻",
                                            "F&B" => "🍔",
                                            "Retail" => "👕",
                                            _ => "🏢"
                                        };

                                        <div class="crowdfunding-project-card @GetRiskClass(cfAsset?.RiskLevel)">
                                            <div class="project-header">
                                                <span class="project-icon">@projectIcon</span>
                                                <span class="project-name">@project.ProjectName</span>
                                            </div>
                                            <div class="project-type-badge">@project.ProjectType</div>
                                            <div class="project-stats">
                                                <div class="stat-row">
                                                    <span>@GetText("Return", "Return", "Return", "Return"):</span>
                                                    <span class="success">@((project.ExpectedReturn * 100).ToString("F0"))%/@GetText("tahun", "tahun", "year", "year")</span>
                                                </div>
                                                <div class="stat-row">
                                                    <span>@GetText("Terkunci", "Terkunci", "Lock-up", "Lock-up"):</span>
                                                    <span>@project.LockUpMonths @GetText("bulan", "bulan", "months", "months")</span>
                                                </div>
                                            </div>
                                            <div class="crowdfunding-buy-controls">
                                                <div class="numeric-spin-group">
                                                    <input type="text" inputmode="numeric" value="@GetCrowdfundingAmountDisplay(project.ProjectId)" @oninput="(e) => OnCrowdfundingInput(e, project.ProjectId)"
                                                           placeholder="Min Rp 100.000" class="cf-input" />
                                                    <div class="spin-buttons">
                                                        <button class="spin-btn spin-up" @onclick="() => SpinDictInput(_crowdfundingAmounts, project.ProjectId, 100_000, true, 100_000)" title="+Rp 100.000">&#9650;</button>
                                                        <button class="spin-btn spin-down" @onclick="() => SpinDictInput(_crowdfundingAmounts, project.ProjectId, 100_000, false, 100_000)" title="-Rp 100.000">&#9660;</button>
                                                    </div>
                                                </div>
                                                <button class="cf-buy-btn" @onclick="() => BuyCrowdfunding(project.ProjectId)"
                                                        disabled="@(_isPaused || _gameState.IsGameOver || _gameState.IsEventPending || GetCrowdfundingAmount(project.ProjectId) < 100000 || GetCrowdfundingAmount(project.ProjectId) > _gameState.CashBalance)">
                                                    @GetText("Investasi", "Investasi", "Invest", "Invest")
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>

                                @* Player's Crowdfunding Investments *@
                                @if (_gameState.CrowdfundingInvestments.Any())
                                {
                                    <div class="crowdfunding-investments">
                                        <h4>@GetText("Investasi Urun Dana Anda", "Investasi Urun Dana Anda", "Your Crowdfunding Investments", "Your Crowdfunding Investments")</h4>
                                        <div class="cf-investments-row">
                                            @foreach (var inv in _gameState.CrowdfundingInvestments)
                                            {
                                                <div class="cf-investment-card @(inv.HasFailed ? "failed" : inv.IsMatured ? "matured" : "active")">
                                                    <div class="cf-inv-header">
                                                        <span class="cf-inv-name">@inv.ProjectName</span>
                                                        @if (inv.HasFailed)
                                                        {
                                                            <span class="cf-inv-status failed">❌ @GetText("GAGAL", "GAGAL", "FAILED", "FAILED")</span>
                                                        }
                                                        else if (inv.IsMatured)
                                                        {
                                                            <span class="cf-inv-status matured">✅ @GetText("SELESAI", "SELESAI", "MATURED", "MATURED")</span>
                                                        }
                                                        else
                                                        {
                                                            <span class="cf-inv-status active">@UIIcon("lock") @inv.MonthsRemaining @GetText("bulan lagi", "bulan lagi", "months left", "months left")</span>
                                                        }
                                                    </div>
                                                    <div class="cf-inv-details">
                                                        <span>@GetText("Modal", "Modal", "Invested", "Invested"): Rp @inv.InvestedAmount.ToString("N0")</span>
                                                        @if (!inv.HasFailed)
                                                        {
                                                            <span>@GetText("Nilai", "Nilai", "Value", "Value"): Rp @inv.CurrentValue.ToString("N0")</span>
                                                        }
                                                    </div>
                                                    @if (inv.HasFailed && !string.IsNullOrEmpty(inv.FailureReason))
                                                    {
                                                        <div class="cf-inv-failure">@GetText("Alasan", "Alasan", "Reason", "Reason"): @inv.FailureReason</div>
                                                    }
                                                    <div class="cf-inv-progress">
                                                        <div class="cf-inv-progress-fill @(inv.HasFailed ? "failed" : "")" style="width: @inv.ProgressPercent%"></div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Locked Assets Section -->
                    @{
                        var lockedAssets = _assets?.Values.Where(a => !_gameState.UnlockedAssets.Contains(a.Type)).ToList() ?? new List<AssetDefinition>();
                    }
                    @if (lockedAssets.Any())
                    {
                        <div class="locked-section">
                            <h3>@GetText("Investasi Terkunci", "Investasi Terkunci", "Locked Investments", "Locked Investments")</h3>
                            <div class="locked-grid">
                                @foreach (var asset in lockedAssets)
                                {
                                    var unlockMonth = (asset.UnlockYear - 1) * 12 + asset.UnlockMonth;
                                    var monthsUntilUnlock = unlockMonth - _gameState.TotalGameMonths;
                                    <div class="locked-card">
                                        <span class="lock-icon">@UIIcon("lock")</span>
                                        <span class="locked-name">@GetAssetDisplayName(asset, asset.DisplayName)</span>
                                        <span class="unlock-info">
                                            @if (monthsUntilUnlock > 12)
                                            {
                                                @(GetText($"Terbuka Tahun {asset.UnlockYear}", $"Terbuka Tahun {asset.UnlockYear}", $"Unlocks Year {asset.UnlockYear}", $"Unlocks Year {asset.UnlockYear}"))
                                            }
                                            else if (monthsUntilUnlock > 0)
                                            {
                                                @(GetText($"{monthsUntilUnlock} bulan lagi", $"{monthsUntilUnlock} bulan lagi", $"{monthsUntilUnlock} months left", $"{monthsUntilUnlock} months left"))
                                            }
                                        </span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </section>

                <!-- Right Panel: Performance & Log -->
                <section class="panel panel-right">
                    <!-- Portfolio Performance -->
                    <div class="performance-section">
                        <h3>@GetText("Performa Investasi", "Performa Investasi", "Investment Performance", "Investment Performance")</h3>

                        <!-- Performance Chart -->
                        <div class="performance-chart-container">
                            <div class="chart-label">@GetText("Pertumbuhan Kekayaan", "Pertumbuhan Kekayaan", "Net Worth Growth", "Net Worth Growth")</div>
                            <div class="performance-chart">
                                @if (_performanceHistory != null && _performanceHistory.Count > 1)
                                {
                                    <svg viewBox="0 0 300 100" preserveAspectRatio="none" class="chart-svg">
                                        <line x1="0" y1="25" x2="300" y2="25" class="grid-line"/>
                                        <line x1="0" y1="50" x2="300" y2="50" class="grid-line"/>
                                        <line x1="0" y1="75" x2="300" y2="75" class="grid-line"/>
                                        <polyline points="@GetChartPoints()" class="performance-line"/>
                                    </svg>
                                    <div class="chart-axis">
                                        <span class="axis-label">@GetText("Awal", "Awal", "Start", "Start")</span>
                                        <span class="axis-label">@GetText("Sekarang", "Sekarang", "Now", "Now")</span>
                                    </div>
                                }
                                else
                                {
                                    <div class="no-data">@GetText("Grafik akan muncul seiring waktu...", "Grafik akan muncul seiring waktu...", "Chart will appear over time...", "Chart will appear over time...")</div>
                                }
                            </div>
                        </div>

                        <div class="performance-stat">
                            <span class="perf-label">@GetText("Total Keuntungan Investasi", "Total Keuntungan Investasi", "Total Investment Gain", "Total Investment Gain")</span>
                            <span class="perf-value @(_gameState.TotalInvestmentGainLoss >= 0 ? "positive" : "negative")">
                                @(_gameState.TotalInvestmentGainLoss >= 0 ? "+" : "")Rp @_gameState.TotalInvestmentGainLoss.ToString("N0")
                            </span>
                        </div>
                        @if (_gameState.SavingsInterestEarned != 0)
                        {
                            <div class="performance-stat sub-stat">
                                <span class="perf-label">@Icon("tabungan") @GetText("Bunga Tabungan", "Bunga Tabungan", "Savings Interest", "Savings Interest")</span>
                                <span class="perf-value positive">+Rp @_gameState.SavingsInterestEarned.ToString("N0")</span>
                            </div>
                        }
                        @if (_gameState.DepositoInterestEarned != 0)
                        {
                            <div class="performance-stat sub-stat">
                                <span class="perf-label">@Icon("deposito") @GetText("Bunga Deposito", "Bunga Deposito", "CD Interest", "CD Interest")</span>
                                <span class="perf-value positive">+Rp @_gameState.DepositoInterestEarned.ToString("N0")</span>
                            </div>
                        }
                        @if (_gameState.BondCouponEarned != 0)
                        {
                            <div class="performance-stat sub-stat">
                                <span class="perf-label">@Icon("obligasi") @GetText("Kupon Obligasi", "Kupon Obligasi", "Bond Coupons", "Bond Coupons")</span>
                                <span class="perf-value positive">+Rp @_gameState.BondCouponEarned.ToString("N0")</span>
                            </div>
                        }
                        @if (_gameState.DividendEarned != 0)
                        {
                            <div class="performance-stat sub-stat">
                                <span class="perf-label">@Icon("saham") @GetText("Dividen Saham", "Dividen Saham", "Stock Dividends", "Stock Dividends")</span>
                                <span class="perf-value positive">+Rp @_gameState.DividendEarned.ToString("N0")</span>
                            </div>
                        }
                        @if (_gameState.PortfolioGainLoss != 0)
                        {
                            <div class="performance-stat sub-stat">
                                <span class="perf-label">@UIIcon("chart") @GetText("Portofolio", "Portofolio", "Portfolio", "Portfolio")</span>
                                <span class="perf-value @(_gameState.PortfolioGainLoss >= 0 ? "positive" : "negative")">
                                    @(_gameState.PortfolioGainLoss >= 0 ? "+" : "")Rp @_gameState.PortfolioGainLoss.ToString("N0")
                                </span>
                            </div>
                        }
                        @if (_gameState.CrowdfundingGainLoss != 0)
                        {
                            <div class="performance-stat sub-stat">
                                <span class="perf-label">@Icon("crowdfunding") @GetText("Crowdfunding", "Crowdfunding", "Crowdfunding", "Crowdfunding")</span>
                                <span class="perf-value @(_gameState.CrowdfundingGainLoss >= 0 ? "positive" : "negative")">
                                    @(_gameState.CrowdfundingGainLoss >= 0 ? "+" : "")Rp @_gameState.CrowdfundingGainLoss.ToString("N0")
                                </span>
                            </div>
                        }
                        @if (_gameState.PlayerTotalEventCostPaid > 0)
                        {
                            <div class="performance-stat sub-stat">
                                <span class="perf-label">@UIIcon("warning") @GetText("Total Biaya Kejadian", "Total Biaya Kejadian", "Total Event Costs", "Total Event Costs")</span>
                                <span class="perf-value negative">-Rp @_gameState.PlayerTotalEventCostPaid.ToString("N0")</span>
                            </div>
                        }
                    </div>

                    <div class="divider"></div>

                    <!-- Game History Log -->
                    <div class="log-header" @onclick="() => _logExpanded = !_logExpanded">
                        <h3>@GetText("Riwayat", "Riwayat", "History", "History")</h3>
                        <span class="log-toggle @(_logExpanded ? "expanded" : "")">&#9660;</span>
                    </div>
