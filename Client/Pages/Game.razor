    // Format decimal as "1.000.000" (Indonesian thousands separator)
    private static string FormatRp(decimal value)
    {
        if (value == 0) return "";
        return value.ToString("N0").Replace(",", ".");
    }

    // Parse "1.000.000" or "1000000" back to decimal
    private static decimal ParseRp(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return 0;
        var cleaned = text.Replace(".", "").Replace(",", "").Trim();
        return decimal.TryParse(cleaned, out var val) ? val : 0;
    }

    private void OnSavingsInput(ChangeEventArgs e)
    {
        _savingsAmount = ParseRp(e.Value?.ToString());
        _savingsAmountDisplay = _savingsAmount > 0 ? FormatRp(_savingsAmount) : "";
    }

    private void OnDepositoInput(ChangeEventArgs e)
    {
        _depositoAmount = ParseRp(e.Value?.ToString());
        _depositoAmountDisplay = _depositoAmount > 0 ? FormatRp(_depositoAmount) : "";
    }

    private void OnBondInput(ChangeEventArgs e)
    {
        _bondAmount = ParseRp(e.Value?.ToString());
        _bondAmountDisplay = _bondAmount > 0 ? FormatRp(_bondAmount) : "";
    }

    private void SpinInput(ref decimal amount, ref string display, decimal step, bool up)
    {
        if (up)
            amount += step;
        else
            amount = Math.Max(0, amount - step);
        display = amount > 0 ? FormatRp(amount) : "";
    }

    private void SpinDictInput(Dictionary<string, decimal> dict, string key, decimal step, bool up, decimal defaultVal)
    {
        var current = dict.GetValueOrDefault(key, defaultVal);
        if (up)
            current += step;
        else
            current = Math.Max(0, current - step);
        dict[key] = current;
    }

    private void OnCryptoInput(ChangeEventArgs e, string symbol)
    {
        var val = ParseRp(e.Value?.ToString());
        _cryptoAmounts[symbol] = val;
