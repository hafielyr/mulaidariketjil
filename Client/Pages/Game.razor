    private string GetPlayerPieChartStyle()
    {
        if (_gameState == null) return "";

        var cash = _gameState.PlayerCashPercent;
        var savings = _gameState.PlayerSavingsPercent;
        var deposito = _gameState.PlayerDepositoPercent;
        var bonds = _gameState.PlayerBondPercent;
        var portfolio = _gameState.PlayerPortfolioPercent;

        // Build conic gradient for pie chart
        var segments = new List<string>();
        decimal cumulative = 0;

        if (cash > 0)
        {
            segments.Add($"#4CAF50 {cumulative}% {cumulative + cash}%");
            cumulative += cash;
        }
        if (savings > 0)
        {
            segments.Add($"#2196F3 {cumulative}% {cumulative + savings}%");
            cumulative += savings;
        }
        if (deposito > 0)
        {
            segments.Add($"#9C27B0 {cumulative}% {cumulative + deposito}%");
            cumulative += deposito;
        }
        if (bonds > 0)
        {
            segments.Add($"#FF9800 {cumulative}% {cumulative + bonds}%");
            cumulative += bonds;
        }
        if (portfolio > 0)
        {
            segments.Add($"#E91E63 {cumulative}% {cumulative + portfolio}%");
            cumulative += portfolio;
        }

        if (!segments.Any()) return "background: #ccc;";

        return $"background: conic-gradient({string.Join(", ", segments)});";
    }

