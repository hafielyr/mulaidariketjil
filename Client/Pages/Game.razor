                                                {
                                                    <div class="legend-item"><span class="legend-color cash"></span>@GetText("Kas", "Cash") @_gameState.BotState.CashPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.SavingsPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color savings"></span>@GetText("Tabungan", "Savings") @_gameState.BotState.SavingsPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.DepositoPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color deposito"></span>Deposito @_gameState.BotState.DepositoPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.BondPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color bonds"></span>@GetText("Obligasi", "Bonds") @_gameState.BotState.BondPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.IndexFundPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color index"></span>@GetText("Reksa Dana", "Index Fund") @_gameState.BotState.IndexFundPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.GoldPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color gold"></span>@GetText("Emas", "Gold") @_gameState.BotState.GoldPercent.ToString("F1")%</div>
                                                }
                                            </div>
                                        </div>

                                        <div class="card-breakdown">
                                            <div class="breakdown-item">
                                                <span>💵 @GetText("Kas", "Kas", "Cash", "Cash")</span>
                                                <span>Rp @_gameState.BotState.CashBalance.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>🐖 @GetText("Tabungan", "Tabungan", "Savings", "Savings")</span>
                                                <span>Rp @_gameState.BotState.SavingsBalance.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>🏦 Deposito</span>
                                                <span>Rp @_gameState.BotState.TotalDepositoValue.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>📜 @GetText("Obligasi", "Obligasi", "Bonds", "Bonds")</span>
                                                <span>Rp @_gameState.BotState.TotalBondValue.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>📈 @GetText("Reksa Dana", "Reksa Dana", "Index Fund", "Index Fund")</span>
                                                <span>Rp @_gameState.BotState.IndexFundValue.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>🪙 @GetText("Emas", "Emas", "Gold", "Gold")</span>
                                                <span>Rp @_gameState.BotState.GoldValue.ToString("N0")</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Earnings Comparison -->
                            @if (_gameState.BotState != null)
                            {
                                <div class="earnings-comparison">
                                    <h4>@GetText("Perbandingan Pendapatan", "Perbandingan Pendapatan", "Earnings Comparison", "Earnings Comparison")</h4>
                                    <div class="earnings-grid">
                                        <div class="earnings-item player-earnings">
                                            <span class="earnings-label">@GetText("Keuntungan Kamu", "Keuntungan Anda", "Your Profit", "Your Profit")</span>
                                            <span class="earnings-value @(GetPlayerProfit() >= 0 ? "positive" : "negative")">
                                                @(GetPlayerProfit() >= 0 ? "+" : "")Rp @GetPlayerProfit().ToString("N0")
                                            </span>
                                            <span class="earnings-percent @(GetPlayerProfitPercent() >= 0 ? "positive" : "negative")">
                                                (@(GetPlayerProfitPercent() >= 0 ? "+" : "")@GetPlayerProfitPercent().ToString("F1")%)
                                            </span>
                                        </div>
                                        <div class="earnings-item bot-earnings">
                                            <span class="earnings-label">@GetText("Keuntungan AI", "Keuntungan AI", "AI Profit", "AI Profit")</span>
                                            <span class="earnings-value @(_gameState.BotState.TotalProfit >= 0 ? "positive" : "negative")">
                                                @(_gameState.BotState.TotalProfit >= 0 ? "+" : "")Rp @_gameState.BotState.TotalProfit.ToString("N0")
                                            </span>
                                            <span class="earnings-percent @(_gameState.BotState.ProfitPercent >= 0 ? "positive" : "negative")">
                                                (@(_gameState.BotState.ProfitPercent >= 0 ? "+" : "")@_gameState.BotState.ProfitPercent.ToString("F1")%)
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Comparison Result -->
                            @if (_gameState.BotState != null)
                            {
                                <div class="comparison-result @(GetComparisonResultClass())">
                                    @if (_gameState.NetWorth > _gameState.BotState.NetWorth)
                                    {
                                        var diff = _gameState.NetWorth - _gameState.BotState.NetWorth;
                                        var pct = _gameState.BotState.NetWorth > 0 ? (diff / _gameState.BotState.NetWorth * 100) : 0;
                                        <span class="result-icon">🎉</span>
                                        <span class="result-text">@GetText(
                                            $"Selamat! Kamu mengalahkan AI sebesar Rp {diff:N0} (+{pct:F1}%)",
                                            $"Selamat! Anda mengalahkan AI sebesar Rp {diff:N0} (+{pct:F1}%)",
                                            $"Congratulations! You beat the AI by Rp {diff:N0} (+{pct:F1}%)",
                                            $"Congratulations! You beat the AI by Rp {diff:N0} (+{pct:F1}%)")</span>
                                    }
                                    else if (_gameState.NetWorth < _gameState.BotState.NetWorth)
                                    {
                                        var diff = _gameState.BotState.NetWorth - _gameState.NetWorth;
                                        var pct = _gameState.NetWorth > 0 ? (diff / _gameState.NetWorth * 100) : 0;
                                        <span class="result-icon">📉</span>
                                        <span class="result-text">@GetText(
                                            $"AI menang! Strategi seimbang unggul Rp {diff:N0} (+{pct:F1}%)",
                                            $"AI menang! Strategi seimbang unggul Rp {diff:N0} (+{pct:F1}%)",
                                            $"AI wins! Balanced strategy ahead by Rp {diff:N0} (+{pct:F1}%)",
                                            $"AI wins! Balanced strategy ahead by Rp {diff:N0} (+{pct:F1}%)")</span>
                                    }
                                    else
                                    {
                                        <span class="result-icon">🤝</span>
                                        <span class="result-text">@GetText("Seri! Kamu dan AI sama kaya!", "Seri! Anda dan AI sama kaya!", "Tie! You and AI have equal wealth!", "Tie! You and AI have equal wealth!")</span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="rating">
                            @GetRating(_gameState.NetWorth)
                        </div>
                        <button class="btn-primary" @onclick="RestartGame">@GetText("Main Lagi!", "Main Lagi", "Play Again!", "Play Again")</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Crowdfunding Failure Notification *@
@if (_gameState != null && !string.IsNullOrEmpty(_gameState.CrowdfundingFailureMessage))
