    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;
        if (_savingsAmount <= 0 || _savingsAmount > _gameState.CashBalance) return;

        var result = await GameClient.DepositToSavingsAsync(_savingsAmount);
