    {
        if (_gameState?.BotState == null) return "";
        if (_gameState.NetWorth > _gameState.BotState.NetWorth) return "player-wins";
        if (_gameState.NetWorth < _gameState.BotState.NetWorth) return "bot-wins";
        return "tie-result";
