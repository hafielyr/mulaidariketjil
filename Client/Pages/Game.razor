    private string GetNetWorthComparisonClass(bool isPlayer)
    {
        if (_gameState?.BotState == null) return "";
        var botDisplayNW = _gameState.BotState.DisplayNetWorth;

        if (isPlayer)
        {
            if (_gameState.NetWorth > botDisplayNW) return "winner";
            if (_gameState.NetWorth < botDisplayNW) return "loser";
        }
        else
        {
            if (botDisplayNW > _gameState.NetWorth) return "winner";
            if (botDisplayNW < _gameState.NetWorth) return "loser";
        }
        return "tie";
    }

    private string GetComparisonResultClass()
    {
        if (_gameState?.BotState == null) return "";
        var botDisplayNW = _gameState.BotState.DisplayNetWorth;
        if (_gameState.NetWorth > botDisplayNW) return "player-wins";
        if (_gameState.NetWorth < botDisplayNW) return "bot-wins";
