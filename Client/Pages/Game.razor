    private string GetNetWorthComparisonClass(bool isPlayer)
    {
        if (_gameState?.BotState == null) return "";

        if (isPlayer)
        {
            if (_gameState.NetWorth > _gameState.BotState.NetWorth) return "winner";
            if (_gameState.NetWorth < _gameState.BotState.NetWorth) return "loser";
        }
        else
        {
            if (_gameState.BotState.NetWorth > _gameState.NetWorth) return "winner";
            if (_gameState.BotState.NetWorth < _gameState.NetWorth) return "loser";
        }
        return "tie";
    }

