                                            {
                                                <div class="legend-item"><span class="legend-color cash"></span>@Lang.T("LABEL_CASH") @_gameState.PlayerCashPercent.ToString("F1")%</div>
                                            }
                                            @if (_gameState.PlayerSavingsPercent > 0)
                                            {
                                                <div class="legend-item"><span class="legend-color savings"></span>@Lang.T("LABEL_SAVINGS") @_gameState.PlayerSavingsPercent.ToString("F1")%</div>
                                            }
                                            @if (_gameState.PlayerDepositoPercent > 0)
                                            {
                                                <div class="legend-item"><span class="legend-color deposito"></span>@Lang.T("LABEL_DEPOSITO") @_gameState.PlayerDepositoPercent.ToString("F1")%</div>
                                            }
                                            @if (_gameState.PlayerBondPercent > 0)
                                            {
                                                <div class="legend-item"><span class="legend-color bonds"></span>@Lang.T("LABEL_BONDS") @_gameState.PlayerBondPercent.ToString("F1")%</div>
                                            }
                                            @if (_gameState.PlayerPortfolioPercent > 0)
                                            {
                                                <div class="legend-item"><span class="legend-color portfolio"></span>@Lang.T("LABEL_PORTFOLIO") @_gameState.PlayerPortfolioPercent.ToString("F1")%</div>
                                            }
                                        </div>
                                    </div>

                                    <div class="card-breakdown">
                                        <div class="breakdown-item">
                                            <span>@UIIcon("cash") @Lang.T("LABEL_CASH")</span>
                                            <span>Rp @_gameState.CashBalance.ToString("N0")</span>
                                        </div>
                                        <div class="breakdown-item">
                                            <span>@Icon("tabungan") @Lang.T("LABEL_SAVINGS")</span>
                                            <span>Rp @_gameState.TotalSavingsValue.ToString("N0")</span>
                                        </div>
                                        <div class="breakdown-item">
                                            <span>@Icon("deposito") @Lang.T("LABEL_DEPOSITO")</span>
                                            <span>Rp @_gameState.TotalDepositoValue.ToString("N0")</span>
                                        </div>
                                        <div class="breakdown-item">
                                            <span>@Icon("obligasi") @Lang.T("LABEL_BONDS")</span>
                                            <span>Rp @_gameState.TotalBondValue.ToString("N0")</span>
                                        </div>
                                        <div class="breakdown-item">
                                            <span>@UIIcon("chart") @Lang.T("LABEL_INVESTMENTS")</span>
                                            <span>Rp @_gameState.TotalPortfolioValue.ToString("N0")</span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Bot Card with Pie Chart -->
                                @if (_gameState.BotState != null)
                                {
                                    <div class="comparison-card bot-card">
                                        <div class="card-header">
                                            <span class="card-icon">@UIIcon("bot")</span>
                                            <span class="card-title">AI Advisor</span>
                                        </div>
                                        <div class="card-networth @(GetNetWorthComparisonClass(false))">
                                            <span class="networth-label">@Lang.T("GAMEOVER_NET_WORTH")</span>
                                            <span class="networth-value">Rp @_gameState.BotState.DisplayNetWorth.ToString("N0")</span>
                                            @if (_gameState.BotState.PlayerEventDeduction > 0)
                                            {
                                                <span class="event-deduction">@Lang.T("GAMEOVER_EVENT_DEDUCTION", new Dictionary<string, object>{{"amount", _gameState.BotState.PlayerEventDeduction.ToString("N0")}})</span>
                                            }
                                        </div>

                                        <!-- Bot Pie Chart -->
                                        <div class="pie-chart-container">
                                            <div class="pie-chart" style="@GetBotPieChartStyle()"></div>
                                            <div class="pie-chart-legend">
                                                @if (_gameState.BotState.CashPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color cash"></span>@Lang.T("LABEL_CASH") @_gameState.BotState.CashPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.SavingsPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color savings"></span>@Lang.T("LABEL_SAVINGS") @_gameState.BotState.SavingsPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.DepositoPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color deposito"></span>@Lang.T("LABEL_DEPOSITO") @_gameState.BotState.DepositoPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.BondPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color bonds"></span>@Lang.T("LABEL_BONDS") @_gameState.BotState.BondPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.IndexFundPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color index"></span>@Lang.T("LABEL_INDEX_FUND") @_gameState.BotState.IndexFundPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.StockPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color portfolio"></span>@Lang.T("LABEL_STOCKS") @_gameState.BotState.StockPercent.ToString("F1")%</div>
                                                }
                                                @if (_gameState.BotState.GoldPercent > 0)
                                                {
                                                    <div class="legend-item"><span class="legend-color gold"></span>@Lang.T("LABEL_GOLD") @_gameState.BotState.GoldPercent.ToString("F1")%</div>
                                                }
                                            </div>
                                        </div>

                                        <div class="card-breakdown">
                                            <div class="breakdown-item">
                                                <span>@UIIcon("cash") @Lang.T("LABEL_CASH")</span>
                                                <span>Rp @_gameState.BotState.CashBalance.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>@Icon("tabungan") @Lang.T("LABEL_SAVINGS")</span>
                                                <span>Rp @_gameState.BotState.SavingsBalance.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>@Icon("deposito") @Lang.T("LABEL_DEPOSITO")</span>
                                                <span>Rp @_gameState.BotState.TotalDepositoValue.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>@Icon("obligasi") @Lang.T("LABEL_BONDS")</span>
                                                <span>Rp @_gameState.BotState.TotalBondValue.ToString("N0")</span>
                                            </div>
                                            <div class="breakdown-item">
                                                <span>@Icon("reksadana") @Lang.T("LABEL_INDEX_FUND")</span>
                                                <span>Rp @_gameState.BotState.IndexFundValue.ToString("N0")</span>
                                            </div>
                                            @if (_gameState.BotState.StockValue > 0)
                                            {
                                                <div class="breakdown-item">
                                                    <span>@Icon("saham") @Lang.T("LABEL_STOCKS") @(!string.IsNullOrEmpty(_gameState.BotState.StockTicker) ? $"({_gameState.BotState.StockTicker})" : "")</span>
                                                    <span>Rp @_gameState.BotState.StockValue.ToString("N0")
                                                        @{ var stockProfit = _gameState.BotState.StockValue - _gameState.BotState.StockCost;
                                                           var stockProfitPct = _gameState.BotState.StockCost > 0 ? (stockProfit / _gameState.BotState.StockCost * 100) : 0; }
                                                        <span class="@(stockProfit >= 0 ? "positive" : "negative")">(@(stockProfit >= 0 ? "+" : "")@stockProfitPct.ToString("F0")%)</span>
                                                    </span>
                                                </div>
                                            }
                                            <div class="breakdown-item">
                                                <span>@Icon("emas") @Lang.T("LABEL_GOLD")</span>
                                                <span>Rp @_gameState.BotState.GoldValue.ToString("N0")</span>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Investment Performance Breakdown -->
                            <div class="earnings-comparison">
                                <h4>@Lang.T("PERF_TITLE")</h4>
                                <div class="investment-breakdown">
                                    @if (_gameState.SavingsInterestEarned != 0)
                                    {
                                        <div class="breakdown-row">
                                            <span>@Icon("tabungan") @Lang.T("PERF_SAVINGS_INTEREST")</span>
                                            <span class="positive">+Rp @_gameState.SavingsInterestEarned.ToString("N0")</span>
                                        </div>
                                    }
                                    @if (_gameState.DepositoInterestEarned != 0)
                                    {
                                        <div class="breakdown-row">
                                            <span>@Icon("deposito") @Lang.T("PERF_DEPOSITO_INTEREST")</span>
                                            <span class="positive">+Rp @_gameState.DepositoInterestEarned.ToString("N0")</span>
                                        </div>
                                    }
                                    @if (_gameState.BondCouponEarned != 0)
                                    {
                                        <div class="breakdown-row">
                                            <span>@Icon("obligasi") @Lang.T("PERF_BOND_COUPONS")</span>
                                            <span class="positive">+Rp @_gameState.BondCouponEarned.ToString("N0")</span>
                                        </div>
                                    }
                                    @if (_gameState.DividendEarned != 0)
                                    {
                                        <div class="breakdown-row">
                                            <span>@Icon("saham") @Lang.T("PERF_STOCK_DIVIDENDS")</span>
                                            <span class="positive">+Rp @_gameState.DividendEarned.ToString("N0")</span>
                                        </div>
                                    }
                                    @foreach (var item in _gameState.Portfolio)
                                    {
                                        <div class="breakdown-row">
                                            <span>@Icon(item.AssetType) @item.DisplayName</span>
                                            <span class="@(item.ProfitLoss >= 0 ? "positive" : "negative")">
                                                @(item.ProfitLoss >= 0 ? "+" : "")Rp @item.ProfitLoss.ToString("N0")
                                                (@(item.ProfitLossPercent >= 0 ? "+" : "")@item.ProfitLossPercent.ToString("F1")%)
                                            </span>
                                        </div>
                                    }
                                    @if (_gameState.CrowdfundingGainLoss != 0)
                                    {
                                        <div class="breakdown-row">
                                            <span>@Icon("crowdfunding") Crowdfunding</span>
                                            <span class="@(_gameState.CrowdfundingGainLoss >= 0 ? "positive" : "negative")">
                                                @(_gameState.CrowdfundingGainLoss >= 0 ? "+" : "")Rp @_gameState.CrowdfundingGainLoss.ToString("N0")
                                            </span>
                                        </div>
                                    }
                                    <div class="breakdown-row total-row">
                                        <span>@Lang.T("PERF_TOTAL_GAIN")</span>
                                        <span class="@(_gameState.TotalInvestmentGainLoss >= 0 ? "positive" : "negative")">
                                            @(_gameState.TotalInvestmentGainLoss >= 0 ? "+" : "")Rp @_gameState.TotalInvestmentGainLoss.ToString("N0")
                                        </span>
                                    </div>
                                    @if (_gameState.PlayerTotalEventCostPaid > 0)
                                    {
                                        <div class="breakdown-row event-row">
                                            <span>@UIIcon("warning") @Lang.T("PERF_TOTAL_EVENT_COSTS")</span>
                                            <span class="negative">-Rp @_gameState.PlayerTotalEventCostPaid.ToString("N0")</span>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Earnings Comparison -->
                            @if (_gameState.BotState != null)
                            {
                                <div class="earnings-comparison">
                                    <h4>@Lang.T("GAMEOVER_EARNINGS_COMPARISON")</h4>
                                    <div class="earnings-grid">
                                        <div class="earnings-item player-earnings">
                                            <span class="earnings-label">@Lang.T("GAMEOVER_YOUR_PROFIT")</span>
                                            <span class="earnings-value @(_gameState.TotalInvestmentGainLoss >= 0 ? "positive" : "negative")">
                                                @(_gameState.TotalInvestmentGainLoss >= 0 ? "+" : "")Rp @_gameState.TotalInvestmentGainLoss.ToString("N0")
                                            </span>
                                        </div>
                                        <div class="earnings-item bot-earnings">
                                            <span class="earnings-label">@Lang.T("GAMEOVER_AI_PROFIT")</span>
                                            <span class="earnings-value @(_gameState.BotState.TotalProfit >= 0 ? "positive" : "negative")">
                                                @(_gameState.BotState.TotalProfit >= 0 ? "+" : "")Rp @_gameState.BotState.TotalProfit.ToString("N0")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Comparison Result -->
                            @if (_gameState.BotState != null)
                            {
                                <div class="comparison-result @(GetComparisonResultClass())">
                                    @if (_gameState.NetWorth > _gameState.BotState.DisplayNetWorth)
                                    {
                                        var diff = _gameState.NetWorth - _gameState.BotState.DisplayNetWorth;
                                        var pct = _gameState.BotState.DisplayNetWorth > 0 ? (diff / _gameState.BotState.DisplayNetWorth * 100) : 0;
                                        <span class="result-icon">@UIIcon("trophy")</span>
                                        <span class="result-text">@Lang.T("GAMEOVER_PLAYER_WINS", new Dictionary<string, object>{{"diff", diff.ToString("N0")}, {"pct", pct.ToString("F1")}})</span>
                                    }
                                    else if (_gameState.NetWorth < _gameState.BotState.DisplayNetWorth)
                                    {
                                        var diff = _gameState.BotState.DisplayNetWorth - _gameState.NetWorth;
                                        var pct = _gameState.NetWorth > 0 ? (diff / _gameState.NetWorth * 100) : 0;
                                        <span class="result-icon">@UIIcon("down")</span>
                                        <span class="result-text">@Lang.T("GAMEOVER_AI_WINS", new Dictionary<string, object>{{"diff", diff.ToString("N0")}, {"pct", pct.ToString("F1")}})</span>
                                    }
                                    else
                                    {
                                        <span class="result-icon">@Icon("crowdfunding")</span>
                                        <span class="result-text">@Lang.T("GAMEOVER_TIE")</span>
                                    }
                                </div>
                            }
                        </div>

                        @if (_gameState.IsMultiplayer && _gameState.FinalLeaderboard != null)
                        {
                            <div class="mp-final-leaderboard">
                                <h3>@Lang.T("GAMEOVER_FINAL_RANKINGS")</h3>
                                @foreach (var entry in _gameState.FinalLeaderboard)
                                {
                                    <div class="mp-final-entry @(entry.Rank == 1 ? "mp-winner" : "") @(entry.PlayerName == _playerName ? "mp-self" : "") @(entry.IsBot ? "mp-bot" : "")">
                                        <span class="mp-final-rank">
                                            @if (entry.Rank == 1) { <span>&#x1F3C6;</span> }
                                            else if (entry.Rank == 2) { <span>&#x1F948;</span> }
                                            else if (entry.Rank == 3) { <span>&#x1F949;</span> }
                                            else { <span>#@entry.Rank</span> }
                                        </span>
                                        <span class="mp-final-name">@(entry.IsBot ? "Bot" : entry.PlayerName)</span>
                                        <span class="mp-final-worth">Rp @entry.NetWorth.ToString("N0")</span>
                                    </div>
                                }
                            </div>

                            @if (!_gameState.AllPlayersFinished)
                            {
                                <div class="mp-waiting">
                                    @Lang.T("GAMEOVER_WAITING_PLAYERS")
                                </div>
                            }
                        }

                        <div class="rating">
                            @GetRating(_gameState.NetWorth)
                        </div>
                        @if (_gameState.IsMultiplayer)
                        {
                            <button class="btn-primary" @onclick="BackToMenu">@Lang.T("BTN_BACK_TO_MENU")</button>
                        }
                        else
                        {
                            <button class="btn-primary" @onclick="RestartGame">@Lang.T("BTN_PLAY_AGAIN")</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@* Crowdfunding Failure Notification *@
@if (_gameState != null && !string.IsNullOrEmpty(_gameState.CrowdfundingFailureMessage))
{
    <div class="modal-overlay">
        <div class="crowdfunding-failure-notification">
            <div class="cf-failure-header">
                <span class="cf-failure-icon">@UIIcon("down")</span>
                <span class="cf-failure-title">@Lang.T("CF_PROJECT_FAILED")</span>
            </div>
            <div class="cf-failure-message">@_gameState.CrowdfundingFailureMessage</div>
            <button class="cf-failure-dismiss" @onclick="DismissCrowdfundingFailure">
                @Lang.T("BTN_I_UNDERSTAND")
            </button>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="error-toast">@_errorMessage</div>
}

@code {
    private string _playerName = "";
    private string? _connectionError = null;
    private string _errorMessage = "";
    private bool _isConnected = false;
    private bool _isPaused = false;
    private bool _showAssetInfo = false;
    private AssetDefinition? _selectedAsset;
    private GameState? _gameState;
    private Dictionary<string, AssetDefinition>? _assets;
    private List<DepositoRate>? _depositoRates;
    private List<BondRate>? _bondRates;
    private int _selectedDepositoPeriod = 0;
    private decimal _depositoAmount = 1_000_000;
    private string _depositoAmountDisplay = "1.000.000";
    private bool _depositoAutoRollOver = false;
    private bool _showAroInfo = false;
    private string _selectedBondType = "";
    private decimal _bondAmount = 1_000_000;
    private string _bondAmountDisplay = "1.000.000";
    private decimal _savingsAmount = 1_000_000;
    private string _savingsAmountDisplay = "1.000.000";
    private bool _isLightMode = false;
    private AgeMode _selectedAgeMode => _isLightMode ? AgeMode.Kids : AgeMode.Adult;
    private Language _selectedLanguage = Language.Indonesian;
    private bool _showLangDropdown = false;
    private Dictionary<string, int> _stockLots = new();
    private Dictionary<string, decimal> _cryptoAmounts = new();
    private Dictionary<string, decimal> _crowdfundingAmounts = new();
    private List<decimal> _performanceHistory = new();

    // Log history state
    private bool _logExpanded = false;

    // Tutorial state
    private bool _showTutorial = false;
    private int _currentTutorialSlide = 0;

    // Multiplayer state
    private string _multiplayerScreen = "none"; // none, create-join, create, join, lobby
    private RoomInfo? _currentRoom;
    private string _roomCodeInput = "";
    private string? _roomError;
    private bool _isCreatingRoom;
    private bool _isJoiningRoom;
    private bool _isHost;
    private bool _isReady;
    private int _maxPlayers = 4;
    private List<LeaderboardEntry>? _leaderboard;

    protected override async Task OnInitializedAsync()
    {
        await Lang.InitializeAsync();
        Lang.SetLanguage(_selectedLanguage, _selectedAgeMode);

        GameClient.OnGameStateUpdated += HandleGameStateUpdated;
        GameClient.OnGamePaused += HandleGamePaused;
        GameClient.OnGameResumed += HandleGameResumed;
        GameClient.OnError += HandleError;

        // Multiplayer event handlers
        GameClient.OnRoomUpdated += HandleRoomUpdated;
        GameClient.OnRoomGameStarted += HandleRoomGameStarted;
        GameClient.OnLeaderboardUpdated += HandleLeaderboardUpdated;
        GameClient.OnAllPlayersFinished += HandleAllPlayersFinished;
        GameClient.OnRoomClosed += HandleRoomClosed;
        GameClient.OnRoomError += HandleRoomError;
        GameClient.OnLeftRoom += HandleLeftRoom;
        GameClient.OnHostChanged += HandleHostChanged;

        try
        {
            var baseUri = NavigationManager.BaseUri;
            await GameClient.ConnectAsync(baseUri);
            _assets = await GameClient.GetAssetDefinitionsAsync();
            _depositoRates = await GameClient.GetDepositoRatesAsync();
            _bondRates = await GameClient.GetBondRatesAsync();
            _isConnected = true;
        }
        catch (Exception ex)
        {
            _connectionError = Lang.T("ERR_CONNECTION", new Dictionary<string, object>{{"message", ex.Message}});
        }

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ApplyTheme();
        }
    }

    private async Task ApplyTheme()
    {
        try
        {
            var theme = (_gameState?.AgeMode ?? _selectedAgeMode) == AgeMode.Adult ? "adult" : "";
            await JSRuntime.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{theme}')");
        }
        catch { /* Silently fail if JS isn't available */ }
    }

    // Currency formatting helper - formats with 2 decimal places
    private string FormatCurrency(decimal amount)
    {
        return amount.ToString("N2");
    }

    private string GetAssetDisplayName(AssetDefinition? asset, string fallback)
    {
        if (asset == null) return fallback;
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.DisplayName,
            (AgeMode.Kids, Language.English) => asset.DisplayNameEN,
            (AgeMode.Adult, Language.Indonesian) => asset.DisplayNameAdult,
            (AgeMode.Adult, Language.English) => asset.DisplayNameAdultEN,
            _ => asset.DisplayName
        };
    }

    private string GetAssetDescription(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.Description,
            (AgeMode.Kids, Language.English) => asset.DescriptionEN,
            (AgeMode.Adult, Language.Indonesian) => asset.DescriptionAdult,
            (AgeMode.Adult, Language.English) => asset.DescriptionAdultEN,
            _ => asset.Description
        };
    }

    private string GetAssetWhatIsIt(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.WhatIsIt,
            (AgeMode.Kids, Language.English) => asset.WhatIsItEN,
            (AgeMode.Adult, Language.Indonesian) => asset.WhatIsItAdult,
            (AgeMode.Adult, Language.English) => asset.WhatIsItAdultEN,
            _ => asset.WhatIsIt
        };
    }

    private string GetAssetRiskExplanation(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.RiskExplanation,
            (AgeMode.Kids, Language.English) => asset.RiskExplanationEN,
            (AgeMode.Adult, Language.Indonesian) => asset.RiskExplanationAdult,
            (AgeMode.Adult, Language.English) => asset.RiskExplanationAdultEN,
            _ => asset.RiskExplanation
        };
    }

    private string GetAssetBestFor(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.BestFor,
            (AgeMode.Kids, Language.English) => asset.BestForEN,
            (AgeMode.Adult, Language.Indonesian) => asset.BestForAdult,
            (AgeMode.Adult, Language.English) => asset.BestForAdultEN,
            _ => asset.BestFor
        };
    }

    private string GetAssetExpectedReturn(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.ExpectedReturn,
            (AgeMode.Kids, Language.English) => asset.ExpectedReturnEN,
            (AgeMode.Adult, Language.Indonesian) => asset.ExpectedReturnAdult,
            (AgeMode.Adult, Language.English) => asset.ExpectedReturnAdultEN,
            _ => asset.ExpectedReturn
        };
    }

    private int GetStockLots(string ticker)
    {
        return _stockLots.GetValueOrDefault(ticker, 1);
    }

    private decimal GetCryptoAmount(string symbol)
    {
        return _cryptoAmounts.GetValueOrDefault(symbol, 1_000_000);
    }

    private decimal GetCrowdfundingAmount(string projectId)
    {
        return _crowdfundingAmounts.GetValueOrDefault(projectId, 100_000);
    }

    // Format decimal as "1.000.000" (Indonesian thousands separator)
    private static string FormatRp(decimal value)
    {
        if (value == 0) return "";
        return value.ToString("N0").Replace(",", ".");
    }

    // Parse "1.000.000" or "1000000" back to decimal
    private static decimal ParseRp(string? text)
    {
        if (string.IsNullOrWhiteSpace(text)) return 0;
        var cleaned = text.Replace(".", "").Replace(",", "").Trim();
        return decimal.TryParse(cleaned, out var val) ? val : 0;
    }

