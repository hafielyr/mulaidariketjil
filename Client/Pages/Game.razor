    protected override async Task OnInitializedAsync()
    {
        GameClient.OnGameStateUpdated += HandleGameStateUpdated;
        GameClient.OnGamePaused += HandleGamePaused;
        GameClient.OnGameResumed += HandleGameResumed;
        GameClient.OnError += HandleError;

        // Multiplayer event handlers
        GameClient.OnRoomUpdated += HandleRoomUpdated;
        GameClient.OnRoomGameStarted += HandleRoomGameStarted;
        GameClient.OnLeaderboardUpdated += HandleLeaderboardUpdated;
        GameClient.OnAllPlayersFinished += HandleAllPlayersFinished;
        GameClient.OnRoomClosed += HandleRoomClosed;
        GameClient.OnRoomError += HandleRoomError;
        GameClient.OnLeftRoom += HandleLeftRoom;
        GameClient.OnHostChanged += HandleHostChanged;

        try
        {
            var baseUri = NavigationManager.BaseUri;
            await GameClient.ConnectAsync(baseUri);
            _assets = await GameClient.GetAssetDefinitionsAsync();
            _depositoRates = await GameClient.GetDepositoRatesAsync();
            _bondRates = await GameClient.GetBondRatesAsync();
            _isConnected = true;
        }
        catch (Exception ex)
        {
            _connectionError = $"Gagal terhubung: {ex.Message}";
        }

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ApplyTheme();
        }
    }

    private async Task ApplyTheme()
    {
        try
        {
            var theme = (_gameState?.AgeMode ?? _selectedAgeMode) == AgeMode.Adult ? "adult" : "";
            await JSRuntime.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{theme}')");
        }
        catch { /* Silently fail if JS isn't available */ }
    }

