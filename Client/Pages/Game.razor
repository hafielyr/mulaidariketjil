                                        <span>✅ @GetText("Bayar dari Kas", "Bayar dari Kas", "Pay from Cash", "Pay from Cash")</span>
                                    }
                                    else
                                    {
                                        <span>❌ @GetText("Uang Tidak Cukup", "Uang Tidak Cukup", "Insufficient Funds", "Insufficient Funds")</span>
                                    }
