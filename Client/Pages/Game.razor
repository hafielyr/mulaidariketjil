    private void SpinInput(ref decimal amount, ref string display, decimal step, bool up)
    {
        if (up)
            amount += step;
        else
            amount = Math.Max(0, amount - step);
        display = amount > 0 ? FormatRp(amount) : "";
    }

    private void SpinDictInput(Dictionary<string, decimal> dict, string key, decimal step, bool up, decimal defaultVal)
    {
        var current = dict.GetValueOrDefault(key, defaultVal);
        if (up)
            current += step;
        else
            current = Math.Max(0, current - step);
        dict[key] = current;
    }

