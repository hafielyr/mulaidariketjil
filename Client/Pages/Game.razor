            (AgeMode.Adult, Language.Indonesian) => asset.WhatIsItAdult,
            (AgeMode.Adult, Language.English) => asset.WhatIsItAdultEN,
            _ => asset.WhatIsIt
        };
    }

    private string GetAssetRiskExplanation(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.RiskExplanation,
            (AgeMode.Kids, Language.English) => asset.RiskExplanationEN,
            (AgeMode.Adult, Language.Indonesian) => asset.RiskExplanationAdult,
            (AgeMode.Adult, Language.English) => asset.RiskExplanationAdultEN,
            _ => asset.RiskExplanation
        };
    }

    private string GetAssetBestFor(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.BestFor,
            (AgeMode.Kids, Language.English) => asset.BestForEN,
            (AgeMode.Adult, Language.Indonesian) => asset.BestForAdult,
            (AgeMode.Adult, Language.English) => asset.BestForAdultEN,
            _ => asset.BestFor
        };
    }

    private string GetAssetExpectedReturn(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.ExpectedReturn,
            (AgeMode.Kids, Language.English) => asset.ExpectedReturnEN,
            (AgeMode.Adult, Language.Indonesian) => asset.ExpectedReturnAdult,
            (AgeMode.Adult, Language.English) => asset.ExpectedReturnAdultEN,
            _ => asset.ExpectedReturn
        };
    }

    private int GetStockLots(string ticker)
    {
        return _stockLots.GetValueOrDefault(ticker, 1);
    }

    private decimal GetCryptoAmount(string symbol)
    {
        return _cryptoAmounts.GetValueOrDefault(symbol, 1_000_000);
    }

    private decimal GetCrowdfundingAmount(string projectId)
    {
        return _crowdfundingAmounts.GetValueOrDefault(projectId, 100_000);
    }

    private string GetChartPoints()
    {
        if (_performanceHistory == null || _performanceHistory.Count < 2)
            return "";

        var max = _performanceHistory.Max();
        var min = _performanceHistory.Min();
        var range = max - min;
        if (range == 0) range = 1; // Avoid division by zero

        var points = new List<string>();
        var width = 300;
        var height = 100;

        for (int i = 0; i < _performanceHistory.Count; i++)
        {
            var x = (double)i / (_performanceHistory.Count - 1) * width;
            var normalizedValue = (double)((_performanceHistory[i] - min) / range);
            var y = height - (normalizedValue * height * 0.8) - (height * 0.1); // 80% of height with 10% margins
            points.Add($"{x:F1},{y:F1}");
        }

        return string.Join(" ", points);
    }

    private string GetAssetIcon(string assetType)
    {
        return assetType switch
        {
            "tabungan" => "\U0001F416",
            "deposito" => "\U0001F3E6",
            "obligasi" => "\U0001F4DC",
            "emas" => "\U0001FA99",
            "reksadana" => "\U0001F4CA",
            "saham" => "\U0001F4C8",
            "crypto" => "\U0001F310",
            "crowdfunding" => "\U0001F91D",
            _ => "\U0001F4B0"
        };
    }

    private string GetGameOverTitle(decimal netWorth, string? reason)
    {
        if (!string.IsNullOrEmpty(reason))
            return GetText("\U0001F622 Game Over!", "\U0001F622 Game Over!");
        if (netWorth >= 500_000_000)
            return GetText("\U0001F3C6 LEGENDA!", "\U0001F3C6 LEGENDARY INVESTOR!");
        if (netWorth >= 300_000_000)
            return GetText("\U0001F947 KEREN BANGET!", "\U0001F947 EXCELLENT!");
        if (netWorth >= 200_000_000)
            return GetText("\U0001F948 HEBAT!", "\U0001F948 GREAT!");
        if (netWorth >= 100_000_000)
            return GetText("\U0001F949 BAGUS!", "\U0001F949 GOOD!");
        return GetText("\U0001F3AE Permainan Selesai!", "\U0001F3AE Game Complete!");
    }

    // Tutorial methods
    private void ShowTutorial()
    {
        if (string.IsNullOrWhiteSpace(_playerName)) return;
        _showTutorial = true;
        _currentTutorialSlide = 0;
    }

    private void SkipTutorial()
    {
        _showTutorial = false;
        _ = StartGame();
    }

    private void NextTutorialSlide()
    {
        if (_currentTutorialSlide < 4)
            _currentTutorialSlide++;
    }

    private void PreviousTutorialSlide()
    {
        if (_currentTutorialSlide > 0)
            _currentTutorialSlide--;
    }

    private void StartGameAfterTutorial()
    {
        _showTutorial = false;
        _ = StartGame();
    }

    private async Task StartGame()
    {
        if (string.IsNullOrWhiteSpace(_playerName)) return;

        _gameState = await GameClient.StartGameAsync(_playerName, _selectedAgeMode, _selectedLanguage);
        _isPaused = false;
        await ApplyTheme();

        // Initialize stock lots dictionary
        if (_gameState?.AvailableStocks != null)
        {
            foreach (var stock in _gameState.AvailableStocks)
            {
                _stockLots[stock.Ticker] = 1;
            }
        }

        // Initialize crypto amounts dictionary
        if (_gameState?.AvailableCryptos != null)
        {
            foreach (var crypto in _gameState.AvailableCryptos)
            {
                _cryptoAmounts[crypto.Symbol] = 1_000_000;
            }
        }

        StateHasChanged();
    }

    private async Task DepositToSavings()
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;
        if (_savingsAmount <= 0 || _savingsAmount > _gameState.CashBalance) return;

        var result = await GameClient.DepositToSavingsAsync(_savingsAmount);
        if (!result)
        {
            ShowError(GetText("Gagal setor ke tabungan!", "Failed to deposit to savings!"));
        }
    }

    private async Task WithdrawFromSavings()
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;
        if (_savingsAmount <= 0 || _savingsAmount > (_gameState.SavingsAccount?.Balance ?? 0)) return;

        var result = await GameClient.WithdrawFromSavingsAsync(_savingsAmount);
        if (!result)
        {
            ShowError(GetText("Gagal tarik dari tabungan!", "Failed to withdraw from savings!"));
        }
    }

    private async Task BuyAsset(string assetType)
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;

        var result = await GameClient.BuyAssetAsync(assetType);
        if (!result)
        {
            ShowError(GetText("Uang tidak cukup! Butuh Rp 1 juta.", "Insufficient funds! Need Rp 1 million."));
        }
    }

    private async Task BuyDeposito()
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;
        if (_selectedDepositoPeriod == 0 || _depositoAmount < 1_000_000) return;

        var result = await GameClient.BuyDepositoAsync(_selectedDepositoPeriod, _depositoAmount, _depositoAutoRollOver);
        if (result)
        {
            _depositoAmount = 1_000_000;
            _selectedDepositoPeriod = 0;
            _depositoAutoRollOver = false; // Reset checkbox after purchase
        }
        else
        {
            ShowError(GetText("Gagal buka deposito. Cek uangmu!", "Failed to open CD. Check your balance!"));
        }
    }

    private async Task WithdrawDeposito(string depositoId, bool earlyWithdraw)
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;

        var result = await GameClient.WithdrawDepositoAsync(depositoId, earlyWithdraw);
        if (!result)
        {
            ShowError(GetText("Gagal ambil deposito.", "Failed to withdraw CD."));
        }
    }

    private async Task ToggleDepositoAutoRollOver(string depositoId)
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;

        await GameClient.ToggleDepositoAutoRollOverAsync(depositoId);
    }

    private async Task BuyBond()
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;
        if (string.IsNullOrEmpty(_selectedBondType) || _bondAmount < 1_000_000) return;

        var result = await GameClient.BuyBondAsync(_selectedBondType, _bondAmount);
        if (result)
        {
            _bondAmount = 1_000_000;
            _selectedBondType = "";
        }
        else
        {
            ShowError(GetText("Gagal beli obligasi. Cek uangmu!", "Failed to buy bond. Check your balance!"));
        }
    }

    private async Task WithdrawBond(string bondId)
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;

        var result = await GameClient.WithdrawBondAsync(bondId);
        if (!result)
        {
            ShowError(GetText("Gagal ambil obligasi.", "Failed to withdraw bond."));
        }
    }

    private async Task BuyStock(string ticker, int lots = 0)
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;

        if (lots == 0)
            lots = GetStockLots(ticker);

        if (lots < 1) return;

        var result = await GameClient.BuyStockAsync(ticker, lots);
        if (!result)
        {
            ShowError(GetText("Gagal beli saham. Cek uangmu!", "Failed to buy stock. Check your balance!"));
        }
    }

    private async Task SellStock(string ticker, int lots)
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;

        var result = await GameClient.SellStockAsync(ticker, lots);
        if (!result)
        {
            ShowError(GetText("Gagal jual saham.", "Failed to sell stock."));
        }
    }

    private async Task SellAllStock(string ticker)
    {
        if (_gameState == null || _isPaused || _gameState.IsGameOver || _gameState.IsEventPending) return;

        var stockItem = _gameState.Portfolio.FirstOrDefault(p => p.Ticker == ticker && p.AssetType == "saham");
        if (stockItem == null || stockItem.Units < 100) return;

        var lotsToSell = (int)(stockItem.Units / 100);
        var result = await GameClient.SellStockAsync(ticker, lotsToSell);
        if (!result)
        {
            ShowError(GetText("Gagal jual saham.", "Failed to sell stock."));
        }
    }

