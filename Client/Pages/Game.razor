    private string GetAssetBestFor(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.BestFor,
            (AgeMode.Kids, Language.English) => asset.BestForEN,
            (AgeMode.Adult, Language.Indonesian) => asset.BestForAdult,
