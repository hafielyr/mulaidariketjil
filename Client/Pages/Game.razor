        if (string.IsNullOrWhiteSpace(_playerName)) return;

        _gameState = await GameClient.StartGameAsync(_playerName, _selectedAgeMode, _selectedLanguage);
        _isPaused = false;
        await ApplyTheme();

        // Initialize stock lots dictionary
        if (_gameState?.AvailableStocks != null)
