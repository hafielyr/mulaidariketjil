    private void HandleGameStateUpdated(GameState state)
    {
        _gameState = state;

        // Update stock lots dictionary when stocks change
        if (state.AvailableStocks != null)
        {
            foreach (var stock in state.AvailableStocks)
            {
                if (!_stockLots.ContainsKey(stock.Ticker))
                {
                    _stockLots[stock.Ticker] = 1;
                }
            }
        }

        // Update crypto amounts dictionary when cryptos change
        if (state.AvailableCryptos != null)
        {
            foreach (var crypto in state.AvailableCryptos)
            {
                if (!_cryptoAmounts.ContainsKey(crypto.Symbol))
                {
                    _cryptoAmounts[crypto.Symbol] = 1_000_000;
                }
            }
        }

        // Update crowdfunding amounts dictionary when projects change
        if (state.AvailableCrowdfunding != null)
        {
            foreach (var project in state.AvailableCrowdfunding)
            {
                if (!_crowdfundingAmounts.ContainsKey(project.ProjectId))
                {
                    _crowdfundingAmounts[project.ProjectId] = 100_000;
                }
            }
        }

        // Track performance history (net worth over time)
        _performanceHistory.Add(state.NetWorth);
        if (_performanceHistory.Count > 120) // Keep last 120 months (10 years)
            _performanceHistory.RemoveAt(0);

        InvokeAsync(StateHasChanged);
    }

    private void HandleGamePaused()
    {
        _isPaused = true;
        InvokeAsync(StateHasChanged);
    }

    private void HandleGameResumed()
    {
        _isPaused = false;
        InvokeAsync(StateHasChanged);
    }

    private void HandleError(string error)
    {
