@code {
    private string _playerName = "";
    private string _statusMessage = "Menghubungkan ke server...";
    private string _errorMessage = "";
    private bool _isConnected = false;
    private bool _isPaused = false;
    private bool _showAssetInfo = false;
    private AssetDefinition? _selectedAsset;
    private GameState? _gameState;
    private Dictionary<string, AssetDefinition>? _assets;
    private List<DepositoRate>? _depositoRates;
    private List<BondRate>? _bondRates;
    private int _selectedDepositoPeriod = 0;
    private decimal _depositoAmount = 1_000_000;
    private bool _depositoAutoRollOver = false;
    private string _selectedBondType = "";
    private decimal _bondAmount = 1_000_000;
    private decimal _savingsAmount = 1_000_000;
    private bool _isLightMode = false;
    private AgeMode _selectedAgeMode => _isLightMode ? AgeMode.Kids : AgeMode.Adult;
    private Language _selectedLanguage = Language.Indonesian;
    private Dictionary<string, int> _stockLots = new();
    private Dictionary<string, decimal> _cryptoAmounts = new();
    private Dictionary<string, decimal> _crowdfundingAmounts = new();
    private List<decimal> _performanceHistory = new();

    // Tutorial state
    private bool _showTutorial = false;
    private int _currentTutorialSlide = 0;

    protected override async Task OnInitializedAsync()
    {
        GameClient.OnGameStateUpdated += HandleGameStateUpdated;
        GameClient.OnGamePaused += HandleGamePaused;
        GameClient.OnGameResumed += HandleGameResumed;
        GameClient.OnError += HandleError;

        try
        {
            var baseUri = NavigationManager.BaseUri;
            await GameClient.ConnectAsync(baseUri);
            _assets = await GameClient.GetAssetDefinitionsAsync();
            _depositoRates = await GameClient.GetDepositoRatesAsync();
            _bondRates = await GameClient.GetBondRatesAsync();
            _isConnected = true;
            _statusMessage = "Terhubung!";
        }
        catch (Exception ex)
        {
            _statusMessage = $"Gagal terhubung: {ex.Message}";
        }

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ApplyTheme();
        }
    }

    private async Task ApplyTheme()
    {
        try
        {
            var theme = (_gameState?.AgeMode ?? _selectedAgeMode) == AgeMode.Adult ? "adult" : "";
            await JSRuntime.InvokeVoidAsync("eval", $"document.documentElement.setAttribute('data-theme', '{theme}')");
        }
        catch { /* Silently fail if JS isn't available */ }
    }

    // Full 4-parameter version for complete translations
    private string GetText(string kidsID, string adultID, string kidsEN, string adultEN)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => kidsID,
            (AgeMode.Kids, Language.English) => kidsEN,
            (AgeMode.Adult, Language.Indonesian) => adultID,
            (AgeMode.Adult, Language.English) => adultEN,
            _ => kidsID
        };
    }

    // Backward compatibility: 2-parameter version (uses Indonesian adult for English)
    private string GetText(string kidsText, string adultText)
    {
        return GetText(kidsText, adultText, kidsText, adultText);
    }

    // Currency formatting helper - formats with 2 decimal places
    private string FormatCurrency(decimal amount)
    {
        return amount.ToString("N2");
    }

    private string GetAssetDisplayName(AssetDefinition? asset, string fallback)
    {
        if (asset == null) return fallback;
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.DisplayName,
            (AgeMode.Kids, Language.English) => asset.DisplayNameEN,
            (AgeMode.Adult, Language.Indonesian) => asset.DisplayNameAdult,
            (AgeMode.Adult, Language.English) => asset.DisplayNameAdultEN,
            _ => asset.DisplayName
        };
    }

    private string GetAssetDescription(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.Description,
            (AgeMode.Kids, Language.English) => asset.DescriptionEN,
            (AgeMode.Adult, Language.Indonesian) => asset.DescriptionAdult,
            (AgeMode.Adult, Language.English) => asset.DescriptionAdultEN,
            _ => asset.Description
        };
    }

    private string GetAssetWhatIsIt(AssetDefinition asset)
    {
        var mode = _gameState?.AgeMode ?? _selectedAgeMode;
        var lang = _gameState?.Language ?? _selectedLanguage;

        return (mode, lang) switch
        {
            (AgeMode.Kids, Language.Indonesian) => asset.WhatIsIt,
            (AgeMode.Kids, Language.English) => asset.WhatIsItEN,
            (AgeMode.Adult, Language.Indonesian) => asset.WhatIsItAdult,
            (AgeMode.Adult, Language.English) => asset.WhatIsItAdultEN,
            _ => asset.WhatIsIt
        };
    }

    private string GetAssetRiskExplanation(AssetDefinition asset)
    {
