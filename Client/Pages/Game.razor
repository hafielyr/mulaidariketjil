                                            @if (entry.Rank == 1) { <span>&#x1F3C6;</span> }
                                            else if (entry.Rank == 2) { <span>&#x1F948;</span> }
                                            else if (entry.Rank == 3) { <span>&#x1F949;</span> }
                                            else { <span>#@entry.Rank</span> }
                                        </span>
                                        <span class="mp-final-name">@(entry.IsBot ? "Bot" : entry.PlayerName)</span>
                                        <span class="mp-final-worth">Rp @entry.NetWorth.ToString("N0")</span>
