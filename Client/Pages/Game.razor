                                    }
                                </div>
                            }
                        </div>

                        @if (_gameState.IsMultiplayer && _gameState.FinalLeaderboard != null)
                        {
                            <div class="mp-final-leaderboard">
                                <h3>@GetText("Peringkat Akhir", "Peringkat Akhir", "Final Rankings", "Final Rankings")</h3>
