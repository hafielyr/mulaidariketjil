                                        }
                                        else
                                        {
                                            <span>❌ @GetText("Tabungan Tidak Cukup", "Tabungan Tidak Cukup", "Insufficient Savings", "Insufficient Savings")</span>
                                        }
                                    </button>
                                </div>
