                                    <p class="portfolio-note">
                                        @GetText("⚠️ Investasi akan dijual di harga pasar saat ini", "⚠️ Investasi akan dijual di harga pasar saat ini", "⚠️ Investment will be sold at current market price", "⚠️ Investment will be sold at current market price")
                                    </p>
                                </div>
                            }
                        </div>

                        @{
                            var totalAssets = _gameState.CashBalance + _gameState.TotalPortfolioValue + _gameState.TotalSavingsValue;
                            var canPay = totalAssets >= (_gameState.EventCost ?? 0);
