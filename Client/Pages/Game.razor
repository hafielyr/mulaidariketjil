    private int GetStockLots(string ticker)
    {
        return _stockLots.GetValueOrDefault(ticker, 1);
    }

    private decimal GetCryptoAmount(string symbol)
    {
        return _cryptoAmounts.GetValueOrDefault(symbol, 1_000_000);
    }

    private decimal GetCrowdfundingAmount(string projectId)
    {
        return _crowdfundingAmounts.GetValueOrDefault(projectId, 100_000);
    }

    private string GetChartPoints()
    {
        if (_performanceHistory == null || _performanceHistory.Count < 2)
            return "";

        var max = _performanceHistory.Max();
        var min = _performanceHistory.Min();
        var range = max - min;
        if (range == 0) range = 1; // Avoid division by zero

        var points = new List<string>();
        var width = 300;
        var height = 100;

        for (int i = 0; i < _performanceHistory.Count; i++)
        {
            var x = (double)i / (_performanceHistory.Count - 1) * width;
            var normalizedValue = (double)((_performanceHistory[i] - min) / range);
            var y = height - (normalizedValue * height * 0.8) - (height * 0.1); // 80% of height with 10% margins
            points.Add($"{x:F1},{y:F1}");
        }

        return string.Join(" ", points);
    }

